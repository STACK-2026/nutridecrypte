---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import { siteConfig } from "../../site.config";
import { fullUrl } from "../utils/config";
import { jsonLdArticle, jsonLdBreadcrumbs } from "../utils/seo";
import { getLocale } from "../i18n/t";

interface Props {
  title: string;
  description: string;
  date: Date;
  author?: string;
  category?: string;
  tags?: string[];
  image?: string;
  imageAlt?: string;
  slug: string;
  keywords?: string;
  lastReviewed?: Date;
  reviewedBy?: string;
  tldr?: string;
  faq?: { q: string; a: string }[];
  body?: string;
  // Explicit hreflang alternates — pass when the counterpart locale article
  // does not share the same slug (or does not exist at all). Without this,
  // BaseLayout falls back to the naive /fr prefix swap which produces 404s.
  alternates?: { en?: string; fr?: string };
}

// Parse a FAQ written as a markdown section in the article body (## FAQ ...)
// with each question as a ### / #### heading and the answer as the text up to
// the next heading. Returns {q,a} pairs so we can still emit FAQPage JSON-LD
// even when the frontmatter `faq` array is empty (the engine writes FAQs in the
// body, not the frontmatter). This does NOT render anything visible; the body
// slot already shows the FAQ.
function cleanMd(s: string): string {
  return s
    .replace(/\[([^\]]+)\]\([^)]*\)/g, "$1") // [text](url) -> text
    .replace(/\*\*/g, "")
    .replace(/\*/g, "")
    .replace(/`/g, "")
    .replace(/[—–]/g, "-") // em/en dash -> hyphen
    .replace(/^\s*[-*]\s+/gm, "") // strip list bullets
    .replace(/^#{1,6}\s*/gm, "")
    .replace(/\s+/g, " ")
    .trim();
}

function parseBodyFaq(md?: string): { q: string; a: string }[] {
  if (!md) return [];
  const lines = md.split("\n");
  const faqRe = /faq|questions?\s+fr[eé]quent|foire aux questions|frequently asked questions/i;
  let i = 0;
  // Find the FAQ section heading (## or higher level "## ").
  for (; i < lines.length; i++) {
    const m = lines[i].match(/^(#{2,3})\s+(.*)$/);
    if (m && faqRe.test(m[2])) break;
  }
  if (i >= lines.length) return [];
  const sectionLevel = (lines[i].match(/^(#+)/) as RegExpMatchArray)[1].length;
  i++;
  const out: { q: string; a: string }[] = [];
  let curQ: string | null = null;
  let curA: string[] = [];
  const flush = () => {
    if (curQ) {
      const q = cleanMd(curQ.replace(/^\d+[.)]\s*/, ""));
      const a = cleanMd(curA.join("\n"));
      if (q && a) out.push({ q, a });
    }
    curQ = null;
    curA = [];
  };
  for (; i < lines.length; i++) {
    const line = lines[i];
    const heading = line.match(/^(#+)\s+(.*)$/);
    if (heading) {
      const level = heading[1].length;
      if (level <= sectionLevel) {
        // End of the FAQ section.
        flush();
        break;
      }
      // A question heading.
      flush();
      curQ = heading[2];
      continue;
    }
    if (curQ !== null) {
      if (line.trim() === "---") continue;
      curA.push(line);
    }
  }
  flush();
  return out;
}

const {
  title,
  description,
  date,
  author = siteConfig.blog.defaultAuthor,
  category,
  tags = [],
  image,
  imageAlt,
  slug,
  keywords,
  lastReviewed,
  reviewedBy,
  tldr,
  faq = [],
  body,
  alternates,
} = Astro.props;

const dateStr = date.toISOString().split("T")[0];
const reviewedStr = lastReviewed ? lastReviewed.toISOString().split("T")[0] : dateStr;

const locale = getLocale(Astro.url);
const blogBasePath = locale === "fr" ? "/fr/blog" : "/blog";
const articleUrl = fullUrl(`${blogBasePath}/${slug}`);
const homeLabel = locale === "fr" ? "Accueil" : "Home";
const blogLabel = "Blog";
const dateLocale = locale === "fr" ? "fr-FR" : "en-US";

const breadcrumbs = [
  { name: homeLabel, url: siteConfig.url + (locale === "fr" ? "/fr/" : "/") },
  { name: blogLabel, url: fullUrl(blogBasePath) },
  { name: title, url: articleUrl },
];

const jsonLd = [
  jsonLdArticle({
    title,
    description,
    url: articleUrl,
    datePublished: dateStr,
    image,
    author,
    keywords: keywords?.split(",").map((k) => k.trim()),
  }),
  jsonLdBreadcrumbs(breadcrumbs),
];

// FAQPage schema (rich result eligibility) when the article ships an FAQ.
// Prefer the frontmatter `faq` array; otherwise fall back to a FAQ section
// written in the markdown body (## FAQ ...). Visible FAQ is unchanged.
const bodyFaq = faq.length > 0 ? [] : parseBodyFaq(body);
const faqForSchema = faq.length > 0 ? faq : bodyFaq;
if (faqForSchema.length >= 2) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqForSchema.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  });
}

// Speakable (GEO / voice + AI-answer surfaces) targeting the answer-first
// summary and the H1.
jsonLd.push({
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: articleUrl,
  speakable: {
    "@type": "SpeakableSpecification",
    cssSelector: [".article-tldr", "h1"],
  },
});
---

<BaseLayout
  title={`${title} | ${siteConfig.name}`}
  description={description}
  canonicalUrl={articleUrl}
  ogImage={image}
  ogType="article"
  publishedTime={dateStr}
  jsonLd={jsonLd}
  alternates={alternates}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      {category && (
        <span class="inline-block text-sm font-medium px-3 py-1 rounded-full mb-4" style="background: rgb(15 118 110 / 0.1); color: var(--color-primary-dark)">
          {category}
        </span>
      )}
      <h1 class="mb-4">{title}</h1>
      <div class="flex items-center gap-4 text-stone-500 text-sm flex-wrap">
        <span class="font-semibold" style="color: var(--color-primary-dark)">{author}</span>
        <span>|</span>
        <time datetime={dateStr}>
          {date.toLocaleDateString(dateLocale, {
            day: "numeric",
            month: "long",
            year: "numeric",
          })}
        </time>
        {reviewedBy && (
          <span class="text-xs px-2 py-0.5 rounded-full border" style="background: rgb(15 118 110 / 0.08); color: var(--color-primary-dark); border-color: rgb(15 118 110 / 0.2)">
            {locale === "fr" ? "Relu le" : "Reviewed"} {reviewedStr} {locale === "fr" ? "par" : "by"} {reviewedBy}
          </span>
        )}
      </div>
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs bg-stone-100 text-stone-600 px-2 py-1 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {image && (
      <figure class="mb-10">
        <img
          src={image}
          alt={imageAlt || title}
          class="w-full rounded-xl"
          loading="eager"
          width="800"
          height="450"
        />
      </figure>
    )}

    {tldr && (
      <aside class="article-tldr">
        <p class="article-tldr-label">{locale === "fr" ? "En bref" : "In short"}</p>
        <p>{tldr}</p>
      </aside>
    )}

    <div class="prose max-w-none">
      <slot />
    </div>

    {faq.length > 0 && (
      <section class="article-faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">{locale === "fr" ? "Questions fréquentes" : "Frequently asked questions"}</h2>
        {faq.map((f) => (
          <details class="article-faq-item">
            <summary>{f.q}</summary>
            <div class="article-faq-answer"><p>{f.a}</p></div>
          </details>
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .article-tldr {
    max-width: 48rem;
    margin: 0 auto 2rem;
    padding: 1.1rem 1.25rem;
    background: rgb(15 118 110 / 0.06);
    border: 1px solid rgb(15 118 110 / 0.2);
    border-left: 4px solid var(--color-primary, #0f766e);
    border-radius: 0.6rem;
  }
  .article-tldr-label {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-primary-dark, #115e59);
    margin: 0 0 0.35rem;
  }
  .article-tldr p:last-child { margin: 0; line-height: 1.55; }
  .article-faq { max-width: 48rem; margin: 2.5rem auto 0; }
  .article-faq h2 { margin-bottom: 1rem; }
  .article-faq-item {
    border: 1px solid rgb(0 0 0 / 0.1);
    border-radius: 0.6rem;
    margin-bottom: 0.6rem;
    background: #fff;
  }
  .article-faq-item summary {
    cursor: pointer;
    padding: 0.85rem 1rem;
    font-weight: 600;
    list-style: none;
  }
  .article-faq-item summary::-webkit-details-marker { display: none; }
  .article-faq-item summary::after { content: "+"; float: right; color: var(--color-primary, #0f766e); font-weight: 800; }
  .article-faq-item[open] summary::after { content: "\2212"; }
  .article-faq-answer { padding: 0 1rem 1rem; line-height: 1.6; }
</style>
