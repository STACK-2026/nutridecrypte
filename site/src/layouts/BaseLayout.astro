---
import { siteConfig } from "../../site.config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieBanner from "../components/CookieBanner.astro";
import Analytics from "../components/Analytics.astro";
import GA4Tracker from "../components/GA4Tracker.astro";
import EasterEggs from "../components/EasterEggs.astro";
import { getLocale } from "../i18n/t";
import { organizationSchema, websiteSchema } from "../lib/structured-data";
import "../styles/global.css";

// Self-hosted fonts (eliminates fonts.googleapis CDN dependency)
import "@fontsource/plus-jakarta-sans/latin-400.css";
import "@fontsource/plus-jakarta-sans/latin-500.css";
import "@fontsource/plus-jakarta-sans/latin-600.css";
import "@fontsource/plus-jakarta-sans/latin-700.css";
import "@fontsource/plus-jakarta-sans/latin-800.css";
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  jsonLd?: object | object[];
  noIndex?: boolean;
  // Explicit hreflang alternates (used when slug differs per locale,
  // e.g. /affiliate-disclosure <-> /fr/divulgation-affiliation)
  alternates?: { en?: string; fr?: string };
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  publishedTime,
  jsonLd,
  noIndex = false,
  alternates,
} = Astro.props;

const locale = getLocale(Astro.url);
const htmlLang = locale === "fr" ? "fr-FR" : "en-US";
const ogLocale = locale === "fr" ? "fr_FR" : "en_US";

const imageUrl = ogImage?.startsWith("http") ? ogImage : `${siteConfig.url}${ogImage}`;
// Always inject Organization + WebSite schemas, then merge any page-specific JSON-LD
const baseJsonLd = [organizationSchema(), websiteSchema(locale)];
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const jsonLdArray = [...baseJsonLd, ...pageJsonLd];

// Build hreflang pairs
// If the page provides explicit `alternates`, trust them (for localized slugs).
// Otherwise fall back to a naive EN<->FR swap of /fr prefix.
const cleanPath = Astro.url.pathname.replace(/^\/fr/, "") || "/";
const enHref = alternates?.en
  ? (alternates.en.startsWith("http") ? alternates.en : siteConfig.url + alternates.en)
  : siteConfig.url + cleanPath;
const frHref = alternates?.fr
  ? (alternates.fr.startsWith("http") ? alternates.fr : siteConfig.url + alternates.fr)
  : siteConfig.url + "/fr" + (cleanPath === "/" ? "/" : cleanPath);

// The lang switcher in Header points to the other-locale URL.
// Pass it explicitly so Header never has to re-derive it from the raw path
// (which would break for blog articles that only exist in one language).
const langSwitchHref = locale === "fr" ? enHref : frHref;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <!-- 214f7ea71f7d1039 -->
    <!-- e2fd960aa17d9557c5b57b3e4172dda4 -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Fonts self-hosted via @fontsource (see imports in frontmatter) -->

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="author" content={siteConfig.author} />
    <meta name="keywords" content={siteConfig.keywords.join(", ")} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Hreflang (bilingual EN + FR) -->
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="fr" href={frHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />
    <link rel="alternate" type="application/rss+xml" title="NutriDécrypte Blog (EN)" href="/rss.xml" />
    <link rel="alternate" type="application/rss+xml" title="NutriDécrypte Blog (FR)" href="/fr/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteConfig.name} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Analytics tracker (consent gated) -->
    <Analytics />
    <GA4Tracker />

    <!-- Favicon + PWA -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#0f766e" />

    <!-- JSON-LD -->
    {jsonLdArray.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header langSwitchHref={langSwitchHref} />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <EasterEggs />

    <script is:inline>
      // Reveal-on-scroll (inline for immediate execution)
      document.addEventListener("DOMContentLoaded", function() {
        // Broaden the reveal-on-scroll observer to also handle the signature helpers
        var revealEls = document.querySelectorAll(".reveal, .scale-reveal, .blur-reveal, .fade-up");

        // If page loaded with a hash, reveal the targeted element and its
        // reveal ancestors/siblings immediately so deep links never land on
        // an invisible section.
        if (location.hash && location.hash.length > 1) {
          try {
            var hashEl = document.querySelector(location.hash);
            if (hashEl) {
              var el = hashEl;
              var revealClasses = ["reveal", "scale-reveal", "blur-reveal", "fade-up"];
              function hasRevealClass(node) {
                if (!node || !node.classList) return false;
                for (var i = 0; i < revealClasses.length; i++) {
                  if (node.classList.contains(revealClasses[i])) return true;
                }
                return false;
              }
              while (el) {
                if (hasRevealClass(el)) el.classList.add("in-view");
                el = el.parentElement;
              }
              var container = hashEl.parentElement;
              if (container) {
                Array.prototype.forEach.call(container.children, function(s) {
                  if (hasRevealClass(s)) s.classList.add("in-view");
                });
              }
            }
          } catch (e) {}
        }

        if ("IntersectionObserver" in window && revealEls.length) {
          var io = new IntersectionObserver(
            function(entries) {
              entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("in-view");
                  io.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.08, rootMargin: "0px 0px -30px 0px" }
          );
          revealEls.forEach(function(el) {
            if (el.classList.contains("in-view")) return;
            io.observe(el);
          });
        } else {
          revealEls.forEach(function(el) { el.classList.add("in-view"); });
        }

        // Count-up
        var counters = document.querySelectorAll("[data-count-up]");
        if (counters.length && "IntersectionObserver" in window) {
          var cio = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (!entry.isIntersecting) return;
              var el = entry.target;
              var target = parseInt(el.getAttribute("data-count-up") || "0", 10);
              var duration = 1400;
              var startTime = performance.now();
              function tick(now) {
                var progress = Math.min(1, (now - startTime) / duration);
                var eased = 1 - Math.pow(1 - progress, 3);
                el.textContent = Math.round(target * eased).toLocaleString();
                if (progress < 1) requestAnimationFrame(tick);
              }
              requestAnimationFrame(tick);
              cio.unobserve(el);
            });
          }, { threshold: 0.5 });
          counters.forEach(function(c) { cio.observe(c); });
        }

        // Stagger children reveal on scroll
        var staggerEls = document.querySelectorAll(".stagger-children");
        if (staggerEls.length && "IntersectionObserver" in window) {
          var sio = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in-view");
                sio.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1 });
          staggerEls.forEach(function(el) { sio.observe(el); });
        }

        // Subtle parallax on scroll
        var parallaxEls = document.querySelectorAll(".parallax-slow");
        if (parallaxEls.length && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          window.addEventListener("scroll", function() {
            var y = window.scrollY;
            parallaxEls.forEach(function(el) {
              var speed = parseFloat(el.getAttribute("data-parallax-speed") || "0.15");
              el.style.transform = "translateY(" + (y * speed) + "px)";
            });
          }, { passive: true });
        }
      });
    </script>

    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--color-primary-dark);
        color: #ffffff;
        padding: 0.5rem 1rem;
        border-radius: 0 0 0.5rem 0;
        z-index: 100;
      }
      .skip-link:focus {
        left: 0;
      }
    </style>
      <script src="/track.js" defer></script>
  </body>
</html>
