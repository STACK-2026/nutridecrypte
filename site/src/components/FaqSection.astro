---
// Visible FAQ accordion. Pairs with jsonLdFaq() in the page head so the FAQPage
// schema is backed by on-page content (Google requirement) and the answers are
// Speakable (data-speakable) for GEO / voice surfaces.
interface Props {
  faq: Array<{ question: string; answer: string }>;
  locale?: "fr" | "en";
  heading?: string;
}
const { faq, locale = "fr", heading } = Astro.props;
const title = heading || (locale === "fr" ? "Questions fréquentes" : "Frequently asked questions");
---
{faq && faq.length > 0 && (
  <section class="nd-faq" aria-labelledby="nd-faq-title">
    <h2 id="nd-faq-title">{title}</h2>
    {faq.map((item) => (
      <details class="nd-faq-item">
        <summary data-speakable>{item.question}</summary>
        <div class="nd-faq-answer"><p data-speakable>{item.answer}</p></div>
      </details>
    ))}
  </section>
)}

<style>
  .nd-faq { max-width: 48rem; margin: 3rem auto 0; }
  .nd-faq h2 { margin-bottom: 1rem; font-size: 1.5rem; font-weight: 800; }
  .nd-faq-item {
    border: 1px solid rgb(0 0 0 / 0.1);
    border-radius: 0.6rem;
    margin-bottom: 0.6rem;
    background: #fff;
  }
  .nd-faq-item summary {
    cursor: pointer;
    padding: 0.85rem 1rem;
    font-weight: 600;
    list-style: none;
  }
  .nd-faq-item summary::-webkit-details-marker { display: none; }
  .nd-faq-item summary::after { content: "+"; float: right; color: var(--color-primary, #0f766e); font-weight: 800; }
  .nd-faq-item[open] summary::after { content: "\2212"; }
  .nd-faq-answer { padding: 0 1rem 1rem; line-height: 1.6; color: #44403c; }
</style>
