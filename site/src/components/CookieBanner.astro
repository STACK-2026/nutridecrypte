---
import { tr, t, getLocale, localeUrl } from "../i18n/t";
const locale = getLocale(Astro.url);
---

<div id="cookie-banner" class="cookie-banner" role="dialog" aria-labelledby="cookie-title" aria-hidden="true">
  <div class="cookie-inner">
    <div class="cookie-icon" aria-hidden="true">
      <svg viewBox="0 0 48 48" fill="none">
        <defs>
          <linearGradient id="cg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0f766e"/>
            <stop offset="100%" stop-color="#065f46"/>
          </linearGradient>
        </defs>
        <rect x="10" y="8" width="24" height="30" rx="2.5" fill="url(#cg)"/>
        <line x1="14" y1="16" x2="30" y2="16" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" opacity="0.85"/>
        <line x1="14" y1="22" x2="28" y2="22" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" opacity="0.85"/>
        <line x1="14" y1="28" x2="26" y2="28" stroke="#ffffff" stroke-width="1.6" stroke-linecap="round" opacity="0.85"/>
        <circle cx="34" cy="32" r="8" fill="none" stroke="#f59e0b" stroke-width="2.5"/>
        <line x1="40" y1="38" x2="45" y2="43" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
      </svg>
    </div>
    <div class="cookie-content">
      <p id="cookie-title" class="cookie-title">{t(tr.cookie.emoji, locale)}</p>
      <p class="cookie-message">{t(tr.cookie.message, locale)}</p>
      <div class="cookie-actions">
        <button type="button" class="cookie-btn cookie-btn-primary" data-cookie-accept>
          {t(tr.cookie.accept, locale)}
        </button>
        <button type="button" class="cookie-btn cookie-btn-secondary" data-cookie-essential>
          {t(tr.cookie.essential, locale)}
        </button>
        <a href={localeUrl("/cookie-policy", locale)} class="cookie-link">
          {t(tr.cookie.policy, locale)}
        </a>
      </div>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    max-width: 34rem;
    margin: 0 auto;
    z-index: 60;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    box-shadow: 0 30px 80px -20px rgb(15 23 42 / 0.25), 0 10px 30px -10px rgb(15 118 110 / 0.15);
    padding: 1rem 1.25rem;
    transform: translateY(140%);
    opacity: 0;
    transition: transform 520ms cubic-bezier(0.2, 0.8, 0.2, 1), opacity 320ms ease;
    pointer-events: none;
  }
  .cookie-banner.visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .cookie-inner {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  .cookie-icon {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    animation: cookieBounce 2.6s cubic-bezier(0.45, 0, 0.55, 1) infinite;
  }
  @keyframes cookieBounce {
    0%, 40%, 100% { transform: translateY(0) rotate(0); }
    15% { transform: translateY(-3px) rotate(-4deg); }
    25% { transform: translateY(0) rotate(2deg); }
  }
  .cookie-content {
    flex: 1;
    min-width: 0;
  }
  .cookie-title {
    margin: 0 0 0.25rem;
    font-family: var(--font-display);
    font-weight: 800;
    color: var(--color-primary-dark);
    font-size: 0.95rem;
  }
  .cookie-message {
    margin: 0 0 0.85rem;
    color: var(--color-ink-soft);
    font-size: 0.82rem;
    line-height: 1.55;
  }
  .cookie-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }
  .cookie-btn {
    font-family: inherit;
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0.5rem 0.9rem;
    border-radius: 0.5rem;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: all 220ms ease;
  }
  .cookie-btn-primary {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: #ffffff;
    box-shadow: 0 4px 12px -4px rgb(15 118 110 / 0.45);
  }
  .cookie-btn-primary:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 18px -4px rgb(15 118 110 / 0.55);
  }
  .cookie-btn-secondary {
    background: #ffffff;
    color: var(--color-ink);
    border-color: var(--color-border);
  }
  .cookie-btn-secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-dark);
  }
  .cookie-link {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-ink-soft);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .cookie-link:hover {
    color: var(--color-primary-dark);
  }
  @media (prefers-reduced-motion: reduce) {
    .cookie-icon { animation: none; }
    .cookie-banner { transition: opacity 200ms ease; }
  }
</style>

<script>
  const KEY = "nd-cookie-choice";
  const banner = document.getElementById("cookie-banner") as HTMLElement | null;

  function show() {
    if (!banner) return;
    banner.setAttribute("aria-hidden", "false");
    requestAnimationFrame(() => banner.classList.add("visible"));
  }

  function hide() {
    if (!banner) return;
    banner.classList.remove("visible");
    banner.setAttribute("aria-hidden", "true");
  }

  const stored = localStorage.getItem(KEY);
  if (!stored) {
    setTimeout(show, 900);
  }

  document.querySelector("[data-cookie-accept]")?.addEventListener("click", () => {
    localStorage.setItem(KEY, "all");
    hide();
  });
  document.querySelector("[data-cookie-essential]")?.addEventListener("click", () => {
    localStorage.setItem(KEY, "essential");
    hide();
  });
</script>
