---
/**
 * Easter Eggs NutriDécrypte.
 * Keyboard listener : type a secret word to trigger a brand-aware surprise.
 *   nutri    -> E-numbers storm (all 400+ additives flash 2s)
 *   konami   -> up up down down left right left right b a -> même storm
 *   scan     -> full-page scan line sweep (amber)
 *   grade    -> random A..E grade badge stamps
 *   decode   -> chromatic decode flash
 */
---

<script>
  // Console ASCII signature
  console.log(
    `%cNutriDécrypte, décode l'étiquette, pas le marketing.\n` +
    `Tape un de ces mots pour un petit easter egg : nutri, scan, grade, decode.\n` +
    `Tu peux aussi faire le konami (↑↑↓↓←→←→BA).`,
    "color:#0f766e;font-family:ui-monospace,monospace;font-size:12px;line-height:1.6;"
  );

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  // ====== E-NUMBERS STORM ======
  function triggerENumberStorm() {
    if (reduced) return;
    const canvas = document.createElement("canvas");
    canvas.style.cssText = "position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:99999;";
    document.body.appendChild(canvas);
    const ctx = canvas.getContext("2d")!;
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    // Mix of real and plausible E-numbers
    const pool = [
      "E100","E102","E104","E110","E120","E122","E124","E129","E131","E132","E133","E141","E150a","E150d","E151",
      "E160a","E160e","E161b","E163","E170","E171","E200","E202","E210","E211","E220","E223","E250","E251","E270",
      "E282","E296","E297","E300","E301","E306","E320","E321","E322","E330","E331","E407","E410","E412","E415","E420","E421",
      "E440","E450","E451","E460","E466","E471","E472e","E475","E481","E491","E500","E501","E503","E504","E524","E535",
      "E621","E631","E635","E900","E901","E903","E904","E920","E950","E951","E952","E954","E955","E960","E961","E965","E967","E968",
      "E1103","E1105","E1200","E1400","E1403","E1404","E1412","E1414","E1420","E1422","E1442","E1450","E1505","E1510","E1518"
    ];
    const fontSize = 16;
    const columns = Array(Math.floor(canvas.width / (fontSize * 3.5))).fill(0);

    const start = performance.now();
    let running = true;

    function tick() {
      if (!running) return;
      ctx.fillStyle = "rgba(250, 250, 249, 0.08)"; // stone-50 wash
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.font = `700 ${fontSize}px "JetBrains Mono", ui-monospace, monospace`;

      for (let i = 0; i < columns.length; i++) {
        const e = pool[Math.floor(Math.random() * pool.length)];
        const x = fontSize * 3.5 * i + Math.random() * 10;
        const y = columns[i] * fontSize * 1.4;
        // Amber for disputed range, teal for neutral
        const n = parseInt(e.slice(1), 10);
        ctx.fillStyle = (n >= 100 && n <= 180) || (n >= 900 && n <= 970) ? "#f59e0b" : "#0f766e";
        ctx.fillText(e, x, y);
        if (y > canvas.height && Math.random() > 0.97) columns[i] = 0;
        columns[i]++;
      }

      if (performance.now() - start < 2400) {
        requestAnimationFrame(tick);
      } else {
        running = false;
        canvas.style.transition = "opacity 500ms ease";
        canvas.style.opacity = "0";
        setTimeout(() => canvas.remove(), 550);
      }
    }
    requestAnimationFrame(tick);
  }

  // ====== SCAN SWEEP ======
  function triggerScan() {
    if (reduced) return;
    const el = document.createElement("div");
    el.style.cssText = [
      "position:fixed","left:0","right:0","top:0","height:3px",
      "background:linear-gradient(90deg, transparent, #f59e0b, transparent)",
      "box-shadow:0 0 16px rgba(245,158,11,0.8)",
      "pointer-events:none","z-index:99998",
      "transform:translateY(-10px)","transition:transform 1.2s cubic-bezier(0.22,0.61,0.36,1), opacity 400ms ease",
      "opacity:1",
    ].join(";");
    document.body.appendChild(el);
    requestAnimationFrame(() => {
      el.style.transform = `translateY(${window.innerHeight + 20}px)`;
    });
    setTimeout(() => { el.style.opacity = "0"; }, 1200);
    setTimeout(() => el.remove(), 1700);
  }

  // ====== RANDOM GRADE STAMPS ======
  function triggerGrade() {
    if (reduced) return;
    const grades = ["A","B","C","D","E"] as const;
    const colors: Record<string, string> = { A:"#0f766e", B:"#84cc16", C:"#eab308", D:"#f97316", E:"#dc2626" };
    const count = 8;
    for (let i = 0; i < count; i++) {
      const g = grades[Math.floor(Math.random() * grades.length)];
      const badge = document.createElement("div");
      const x = 10 + Math.random() * 80;
      const y = 10 + Math.random() * 70;
      badge.textContent = g;
      badge.style.cssText = [
        "position:fixed",`left:${x}vw`,`top:${y}vh`,
        "width:4rem","height:4rem","border-radius:9999px",
        "display:flex","align-items:center","justify-content:center",
        "font-family:'Plus Jakarta Sans',system-ui,sans-serif",
        "font-weight:900","font-size:2rem","color:#fff",
        `background:linear-gradient(135deg, ${colors[g]}, ${colors[g]}cc)`,
        "box-shadow:0 12px 28px rgba(0,0,0,0.2)",
        "pointer-events:none","z-index:99998",
        "transform:scale(0) rotate(-10deg)","opacity:0",
        "transition:transform 600ms cubic-bezier(0.25,1.5,0.5,1), opacity 400ms ease",
      ].join(";");
      document.body.appendChild(badge);
      setTimeout(() => {
        badge.style.transform = "scale(1) rotate(0deg)";
        badge.style.opacity = "1";
      }, 80 + i * 90);
      setTimeout(() => {
        badge.style.transform = "scale(0.6) rotate(8deg)";
        badge.style.opacity = "0";
      }, 2200 + i * 40);
      setTimeout(() => badge.remove(), 2800 + i * 40);
    }
  }

  // ====== DECODE CHROMATIC FLASH ======
  function triggerDecode() {
    if (reduced) return;
    const style = document.createElement("style");
    style.textContent = `
      @keyframes nd-ee-decode {
        0%   { filter: drop-shadow(rgba(15,118,110,0) 0 0) drop-shadow(rgba(245,158,11,0) 0 0); }
        25%  { filter: drop-shadow(rgba(15,118,110,0.8) 6px 0) drop-shadow(rgba(245,158,11,0.8) -6px 0); }
        50%  { filter: drop-shadow(rgba(245,158,11,0.8) 0 6px) drop-shadow(rgba(220,38,38,0.6) 0 -6px); }
        75%  { filter: drop-shadow(rgba(15,118,110,0.8) -6px 0) drop-shadow(rgba(245,158,11,0.8) 6px 0); }
        100% { filter: drop-shadow(rgba(0,0,0,0) 0 0); }
      }
      body { animation: nd-ee-decode 0.5s ease-in-out 3 !important; }
    `;
    document.head.appendChild(style);
    setTimeout(() => style.remove(), 2000);
  }

  // ====== listeners ======
  let buffer = "";
  const maxLen = 8;
  window.addEventListener("keydown", (e) => {
    const key = e.key.toLowerCase();
    if (key.length !== 1) return;
    buffer = (buffer + key).slice(-maxLen);
    if (buffer.endsWith("nutri")) triggerENumberStorm();
    if (buffer.endsWith("scan")) triggerScan();
    if (buffer.endsWith("grade")) triggerGrade();
    if (buffer.endsWith("decode")) triggerDecode();
  });

  // Konami sequence : ↑↑↓↓←→←→BA
  const konami = ["ArrowUp","ArrowUp","ArrowDown","ArrowDown","ArrowLeft","ArrowRight","ArrowLeft","ArrowRight","b","a"];
  let pos = 0;
  window.addEventListener("keydown", (e) => {
    const want = konami[pos];
    const got = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    if (got === want) {
      pos++;
      if (pos === konami.length) { triggerENumberStorm(); pos = 0; }
    } else {
      pos = got === konami[0] ? 1 : 0;
    }
  });

  // Expose for console-powered debugging
  (window as any).ndEasterEggs = { triggerENumberStorm, triggerScan, triggerGrade, triggerDecode };
</script>
