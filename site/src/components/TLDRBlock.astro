---
// Reusable front-loaded "response-first" TL;DR block for GEO / AI citation.
// Placed right after the H1 on key data pages so LLMs read the answer first.
// Speakable (data-speakable) so AI-answer surfaces can lift it verbatim.
// RULE: only pass figures already visible elsewhere on the page, never invent.
interface Props {
  label?: string;
  // Optional secondary collapsible summary (e.g. the other language).
  altLabel?: string;
  altText?: string;
}
const { label = "TL;DR", altLabel, altText } = Astro.props;
---
<aside data-speakable class="tldr-block">
  <p class="tldr-block-label">{label}</p>
  <p class="tldr-block-body"><slot /></p>
  {altLabel && altText && (
    <details class="tldr-block-alt">
      <summary>{altLabel}</summary>
      <p>{altText}</p>
    </details>
  )}
</aside>

<style>
  .tldr-block {
    background: #fafaf9;
    border-left: 4px solid var(--color-primary, #0f766e);
    border-radius: 0 0.75rem 0.75rem 0;
    padding: 1.25rem 1.5rem;
    margin: 0 0 2.5rem;
  }
  .tldr-block-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary, #0f766e);
    margin: 0 0 0.6rem;
  }
  .tldr-block-body {
    font-size: 1rem;
    line-height: 1.65;
    color: #292524;
    margin: 0;
  }
  .tldr-block-alt {
    margin-top: 0.75rem;
    font-size: 0.875rem;
    color: #57534e;
  }
  .tldr-block-alt summary {
    cursor: pointer;
    font-weight: 500;
  }
  .tldr-block-alt p {
    margin: 0.5rem 0 0;
  }
</style>
