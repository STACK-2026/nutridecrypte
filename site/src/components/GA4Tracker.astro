---
// GA4 tracker, runs ALONGSIDE existing Analytics.astro (Mix mode).
// Same consent gate: respects `nd-cookie-choice` localStorage (must be "all").
const GA4_ID = "G-77EEBGDMMX";
---

<script define:vars={{ GA4_ID }}>
  (function () {
    try {
      const choice = localStorage.getItem("nd-cookie-choice");
      if (choice && choice !== "all") return;
    } catch (e) {}

    const s = document.createElement("script");
    s.async = true;
    s.src = "https://www.googletagmanager.com/gtag/js?id=" + GA4_ID;
    document.head.appendChild(s);

    window.dataLayer = window.dataLayer || [];
    function gtag() {
      window.dataLayer.push(arguments);
    }
    window.gtag = gtag;
    gtag("js", new Date());
    gtag("config", GA4_ID);
  })();
</script>
