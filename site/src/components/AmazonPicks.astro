---
import { buildAmazonSearchUrl, buildAmazonAsinUrl, AMAZON_TAG } from "../lib/affiliate";
import { AMAZON_PICKS, getPicksByTopic, inferTopicFromSlug, type AmazonPick } from "../data/amazon_picks";
import { AMAZON_ASINS } from "../data/amazon_asins";

function resolveUrl(key: string | undefined, query: string): string | null {
  if (key && AMAZON_ASINS[key]) {
    const asinUrl = buildAmazonAsinUrl(AMAZON_ASINS[key]);
    if (asinUrl) return asinUrl;
  }
  return buildAmazonSearchUrl({ query });
}

interface Props {
  topic?: AmazonPick["topic"];
  slug?: string; // blog slug, used for /go/ click attribution + topic inference
  count?: number;
  title?: string;
}

const { topic, slug, count = 3, title } = Astro.props;

// Pick topic: explicit prop wins, else infer from slug, else "general"
const resolved: AmazonPick["topic"] = topic ?? (slug ? inferTopicFromSlug(slug) : "general");

let items = getPicksByTopic(resolved, count);
// Fallback: if no picks for this topic, surface the "general" set.
if (items.length === 0) {
  items = getPicksByTopic("general", count);
}

type Item = { label: string; href: string; highlight?: string };
const rendered: Item[] = items.flatMap((p) => {
  const url = resolveUrl(p.key, p.query);
  if (!url) return [];
  return [{ label: p.label, href: url, highlight: p.highlight }];
});

function wrapGoIfPossible(href: string): string {
  if (!slug) return href;
  return `/go/${encodeURIComponent(slug)}?to=${encodeURIComponent(href)}`;
}

const shouldRender = AMAZON_TAG && rendered.length > 0;
const heading = title ?? "Sélection Amazon pour aller plus loin";
---

{
  shouldRender && (
    <aside class="amazon-picks" data-merchant="amazon">
      <div class="amazon-picks-head">
        <h3 class="amazon-picks-title">{heading}</h3>
        <p class="amazon-picks-disclosure">Liens d'affiliation Amazon · prix inchangé pour toi</p>
      </div>
      <ul class="amazon-picks-list">
        {rendered.map((it) => (
          <li class="amazon-picks-item">
            <a
              class="amazon-picks-link"
              href={wrapGoIfPossible(it.href)}
              rel="nofollow sponsored noopener"
              target="_blank"
              data-merchant="amazon"
            >
              <span class="amazon-picks-label">{it.label}</span>
              {it.highlight && <span class="amazon-picks-highlight">{it.highlight}</span>}
              <span class="amazon-picks-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )
}

<style>
  .amazon-picks {
    margin: 2rem 0;
    padding: 1.4rem 1.5rem 1.25rem;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.08) 0%, rgba(217, 119, 6, 0.04) 100%);
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 12px;
  }
  .amazon-picks-head {
    margin-bottom: 0.9rem;
  }
  .amazon-picks-title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem 0;
    color: var(--text-strong, #0f172a);
  }
  .amazon-picks-disclosure {
    font-size: 0.78rem;
    color: var(--text-muted, #64748b);
    margin: 0;
  }
  .amazon-picks-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .amazon-picks-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    background: white;
    border: 1px solid rgba(245, 158, 11, 0.45);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text-strong, #0f172a);
    font-size: 0.95rem;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .amazon-picks-link:hover {
    border-color: rgb(217, 119, 6);
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(245, 158, 11, 0.25);
  }
  .amazon-picks-link:focus-visible {
    outline: 2px solid rgb(217, 119, 6);
    outline-offset: 3px;
  }
  .amazon-picks-label {
    flex: 1 1 auto;
    font-weight: 600;
  }
  .amazon-picks-highlight {
    flex: 0 0 auto;
    font-size: 0.78rem;
    color: rgb(146, 64, 14);
    background: rgba(245, 158, 11, 0.12);
    padding: 0.18rem 0.55rem;
    border-radius: 4px;
    white-space: nowrap;
  }
  .amazon-picks-arrow {
    flex: 0 0 auto;
    color: rgb(217, 119, 6);
    font-weight: 700;
  }
  @media (max-width: 540px) {
    .amazon-picks-link {
      flex-wrap: wrap;
    }
    .amazon-picks-highlight {
      order: 3;
      flex-basis: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .amazon-picks-link { transition: none; }
    .amazon-picks-link:hover { transform: none; }
  }
</style>
