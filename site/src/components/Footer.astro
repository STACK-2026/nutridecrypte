---
import { siteConfig } from "../../site.config";
import { tr, t, getLocale, localeUrl } from "../i18n/t";

const locale = getLocale(Astro.url);
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grades" aria-hidden="true">
    <span class="grade grade-sm grade-a">A</span>
    <span class="grade grade-sm grade-b">B</span>
    <span class="grade grade-sm grade-c">C</span>
    <span class="grade grade-sm grade-d">D</span>
    <span class="grade grade-sm grade-e">E</span>
  </div>

  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand-row">
          <span class="brand-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none">
              <rect x="3.5" y="4" width="12" height="14" rx="1.5" fill="currentColor" opacity="0.7"/>
              <line x1="6" y1="8" x2="12" y2="8" stroke="#ffffff" stroke-width="1.2" stroke-linecap="round"/>
              <line x1="6" y1="11" x2="11" y2="11" stroke="#ffffff" stroke-width="1.2" stroke-linecap="round"/>
              <line x1="6" y1="14" x2="10" y2="14" stroke="#ffffff" stroke-width="1.2" stroke-linecap="round"/>
              <circle cx="17" cy="16" r="4" fill="none" stroke="currentColor" stroke-width="2"/>
              <line x1="20" y1="19" x2="22.5" y2="21.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </span>
          <p class="brand-name">NutriDécrypte</p>
        </div>
        <p class="brand-tag">{t(tr.footer.tagline, locale)}</p>
        <p class="brand-blurb">{t(tr.footer.blurb, locale)}</p>
      </div>

      <div>
        <p class="col-title">{t(tr.footer.colProduct, locale)}</p>
        <ul>
          <li><a href={localeUrl("/rankings", locale)}>{t(tr.footer.rankings, locale)}</a></li>
          <li><a href={localeUrl("/compare", locale)}>{t(tr.footer.compare, locale)}</a></li>
          <li><a href={localeUrl("/encyclopedia", locale)}>{t(tr.footer.encyclopedia, locale)}</a></li>
          <li><a href={localeUrl("/methodology", locale)}>{t(tr.footer.methodology, locale)}</a></li>
        </ul>
      </div>

      <div>
        <p class="col-title">{t(tr.footer.colCompany, locale)}</p>
        <ul>
          <li><a href={localeUrl("/about", locale)}>{t(tr.footer.about, locale)}</a></li>
          <li><a href={localeUrl("/blog", locale)}>{t(tr.footer.blog, locale)}</a></li>
          <li><a href={`mailto:${siteConfig.legal.email}`}>{t(tr.footer.contact, locale)}</a></li>
        </ul>

        <div class="newsletter-block">
          <p class="nl-title">
            {locale === "fr"
              ? "Reçois les verdicts qui comptent chaque semaine"
              : "Get the verdicts that matter, weekly"}
          </p>
          <form class="nl-form" data-newsletter-form>
            <input type="email" name="email" required placeholder={locale === "fr" ? "ton@email.com" : "your@email.com"} class="nl-input" />
            <button type="submit" class="nl-btn">
              {locale === "fr" ? "S'abonner" : "Subscribe"}
            </button>
            <input type="hidden" name="locale" value={locale} />
          </form>
          <p class="nl-notice" data-nl-notice hidden></p>
        </div>

        <p class="col-title legal-title">{t(tr.footer.colLegal, locale)}</p>
        <ul>
          <li><a href={localeUrl("/privacy-policy", locale)}>{t(tr.footer.privacy, locale)}</a></li>
          <li><a href={localeUrl("/terms", locale)}>{t(tr.footer.terms, locale)}</a></li>
          <li><a href={localeUrl("/cookie-policy", locale)}>{t(tr.footer.cookies, locale)}</a></li>
          <li>
            <a href={locale === "fr" ? "/fr/divulgation-affiliation/" : "/affiliate-disclosure/"}>
              {locale === "fr" ? "Divulgation d'affiliation" : "Affiliate disclosure"}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} NutriDécrypte. Indépendant.</p>
      <p class="disclaimer">{t(tr.footer.disclaimer, locale)}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #0c1a17;
    color: #9db8ab;
    margin-top: auto;
    position: relative;
  }
  .footer-grades {
    position: absolute;
    top: -1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: #0c1a17;
    border: 1px solid #1a3a2f;
    border-radius: 9999px;
    box-shadow: 0 10px 30px -10px rgb(0 0 0 / 0.3);
  }

  .footer-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 4rem 1rem 2rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 2.5rem;
    }
  }
  @media (min-width: 960px) {
    .footer-grid {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 2.5rem;
    }
  }

  .footer-brand {
    color: #cfe4db;
  }
  .brand-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    margin-bottom: 0.5rem;
  }
  .brand-mark {
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, #0f766e, #065f46);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
  }
  .brand-mark svg {
    width: 1.2rem;
    height: 1.2rem;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 800;
    color: #ffffff;
    font-size: 1.1rem;
    margin: 0;
  }
  .brand-tag {
    color: #86c1a8;
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0.25rem 0 0.75rem;
  }
  .brand-blurb {
    font-size: 0.82rem;
    line-height: 1.6;
    color: #9db8ab;
    max-width: 26rem;
    margin: 0;
  }

  .col-title {
    color: #ffffff;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    font-weight: 800;
    margin: 0 0 0.85rem;
  }
  .legal-title {
    margin-top: 1.5rem;
  }

  .site-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .site-footer a {
    color: #cbd5c8;
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 220ms ease;
  }
  .site-footer a:hover {
    color: #5eead4;
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid #1a3a2f;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .copyright {
    font-size: 0.78rem;
    color: #86c1a8;
    margin: 0;
  }
  .disclaimer {
    font-size: 0.72rem;
    line-height: 1.6;
    color: #7e9b8b;
    max-width: 62rem;
    margin: 0;
  }

  .newsletter-block {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #1a3a2f;
  }
  .nl-title {
    font-size: 0.82rem;
    font-weight: 700;
    color: #cfe4db;
    margin: 0 0 0.5rem;
  }
  .nl-form {
    display: flex;
    gap: 0.4rem;
  }
  .nl-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    border: 1px solid #1a3a2f;
    border-radius: 0.5rem;
    background: #0f2a24;
    color: #cfe4db;
    font-size: 0.82rem;
    font-family: inherit;
  }
  .nl-input::placeholder { color: #5a8a76; }
  .nl-input:focus { outline: none; border-color: #0f766e; }
  .nl-btn {
    padding: 0.5rem 1rem;
    background: #0f766e;
    color: #ffffff;
    border: none;
    border-radius: 0.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
    transition: background 200ms ease;
  }
  .nl-btn:hover { background: #115e59; }
  .nl-notice {
    font-size: 0.75rem;
    margin: 0.4rem 0 0;
    color: #5eead4;
  }
</style>

<script is:inline>
document.querySelectorAll("[data-newsletter-form]").forEach(form => {
  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[name="email"]').value;
    const locale = form.querySelector('input[name="locale"]').value;
    const notice = form.parentElement.querySelector("[data-nl-notice]");
    const supabaseUrl = (window.NUTRIDECRYPTE_SUPABASE_URL || "").trim();
    const supabaseKey = (window.NUTRIDECRYPTE_SUPABASE_ANON_KEY || "").trim();

    if (!supabaseUrl || !supabaseKey) {
      notice.textContent = locale === "fr"
        ? "Merci ! Nous activons la newsletter très bientôt."
        : "Thanks! Newsletter going live very soon.";
      notice.hidden = false;
      form.reset();
      return;
    }

    try {
      const resp = await fetch(`${supabaseUrl}/rest/v1/newsletter_subscribers`, {
        method: "POST",
        headers: {
          apikey: supabaseKey,
          Authorization: `Bearer ${supabaseKey}`,
          "Content-Type": "application/json",
          Prefer: "return=minimal",
        },
        body: JSON.stringify({ email, locale, source: "footer" }),
      });
      if (resp.ok) {
        notice.textContent = locale === "fr" ? "Merci ! Tu reçois les prochaines analyses." : "Thanks! You are on the list.";
        notice.hidden = false;
        form.reset();
      } else {
        notice.textContent = locale === "fr" ? "Déjà inscrit ou erreur. Réessaie." : "Already subscribed or error. Try again.";
        notice.hidden = false;
      }
    } catch {
      notice.textContent = "Error";
      notice.hidden = false;
    }
  });
});
</script>
