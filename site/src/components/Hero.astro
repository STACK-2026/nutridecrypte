---
import { siteConfig } from "../../site.config";
import { tr, t, getLocale, localeUrl } from "../i18n/t";

const locale = getLocale(Astro.url);
---

<section class="relative overflow-hidden py-20 md:py-32 px-4">
  <div class="max-w-4xl mx-auto text-center">
    <h1 class="mb-6" data-speakable>
      {siteConfig.tagline}
    </h1>
    <p class="text-lg md:text-xl text-stone-600 max-w-2xl mx-auto mb-10" data-speakable>
      {siteConfig.description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href={localeUrl("/rankings", locale)}
        class="inline-flex items-center justify-center gap-2 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-all hover:scale-105 hover:shadow-lg"
        style={`background: ${siteConfig.colors.primary};`}
      >
        {t(tr.nav.score, locale)}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a
        href={localeUrl("/blog", locale)}
        class="inline-flex items-center justify-center gap-2 text-stone-700 font-semibold px-8 py-4 rounded-xl text-lg border-2 border-stone-200 hover:border-stone-400 transition-all"
      >
        {locale === "fr" ? "Lire le blog" : "Read the blog"}
      </a>
    </div>
  </div>
</section>
