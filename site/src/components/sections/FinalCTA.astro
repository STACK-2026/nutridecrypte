---
import { tr, t, getLocale, localeUrl } from "../../i18n/t";
import BlurText from "../BlurText.astro";

const locale = getLocale(Astro.url);

const finalTitleLine1 = locale === "fr" ? "Lis l'étiquette." : "Read the label.";
const finalTitleLine2 = locale === "fr" ? "Pas le packaging." : "Not the packaging.";

const stats = locale === "fr" ? [
  { num: "400+", label: "additifs décryptés" },
  { num: "5", label: "sources officielles" },
  { num: "100%", label: "gratuit" },
  { num: "0", label: "note achetée" },
] : [
  { num: "400+", label: "additives decoded" },
  { num: "5", label: "official sources" },
  { num: "100%", label: "free" },
  { num: "0", label: "paid grade" },
];
---

<section class="nd-cta" aria-labelledby="nd-cta-title">
  <div class="nd-cta-inner">
    <div class="nd-cta-card">
      <div class="nd-cta-corner nd-cta-corner-tl" aria-hidden="true"></div>
      <div class="nd-cta-corner nd-cta-corner-br" aria-hidden="true"></div>

      <div class="nd-cta-head">
        <span class="nd-cta-label">
          {locale === "fr" ? "Décodage public · Lecture gratuite" : "Public decoding · Free to read"}
        </span>
        <span class="nd-cta-route">
          {locale === "fr" ? "Bourgogne, FR → Europe" : "Burgundy, FR → Europe"}
        </span>
      </div>

      <h2 id="nd-cta-title" class="nd-cta-title">
        <BlurText text={finalTitleLine1} stagger={28} blur={10} /><br />
        <span class="nd-cta-title-accent">
          <BlurText text={finalTitleLine2} stagger={28} blur={10} />
        </span>
      </h2>

      <p class="nd-cta-body">
        {locale === "fr"
          ? "Cherche ton produit, compare les alternatives, lis pourquoi. Aucune marque n'achète sa note. Aucun additif n'est caché."
          : "Search your product, compare alternatives, read why. No brand buys its grade. No additive is hidden."}
      </p>

      <div class="nd-cta-actions">
        <a href={localeUrl("/rankings", locale)} class="nd-cta-btn-primary">
          <span>{t(tr.finalCta.cta, locale)}</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 5l7 7-7 7" />
          </svg>
        </a>
        <a href={localeUrl("/methodology", locale)} class="nd-cta-btn-ghost">
          {locale === "fr" ? "Voir la méthodologie" : "Read the methodology"}
        </a>
      </div>

      <dl class="nd-cta-grid">
        {stats.map((stat) => (
          <div class="nd-cta-stat">
            <dt class="nd-cta-stat-num">{stat.num}</dt>
            <dd class="nd-cta-stat-label">{stat.label}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>
</section>

<style>
  .nd-cta {
    padding: clamp(4.5rem, 10vw, 8.75rem) 0;
    background: linear-gradient(180deg, #ffffff, #fafaf9);
  }
  .nd-cta-inner { max-width: 64rem; margin: 0 auto; padding: 0 1rem; }
  .nd-cta-card {
    position: relative;
    background: #ffffff;
    border: 1px solid rgb(15 118 110 / 0.14);
    border-radius: 4px;
    padding: clamp(2rem, 6vw, 4.5rem);
    box-shadow:
      0 1px 0 rgb(12 10 9 / 0.02),
      0 20px 60px rgb(15 118 110 / 0.06);
  }
  .nd-cta-corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border: 1px solid rgb(15 118 110 / 0.35);
  }
  .nd-cta-corner-tl { top: -5px; left: -5px; border-right: 0; border-bottom: 0; }
  .nd-cta-corner-br { bottom: -5px; right: -5px; border-left: 0; border-top: 0; }
  .nd-cta-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px dashed rgb(15 118 110 / 0.22);
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .nd-cta-label { color: var(--color-primary-dark); font-weight: 600; }
  .nd-cta-route { color: var(--color-ink-soft); }
  .nd-cta-title {
    font-size: clamp(2.25rem, 5vw, 4.25rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 0.98;
    color: var(--color-ink);
    margin: 0 0 1.25rem;
  }
  .nd-cta-title-accent {
    background: linear-gradient(120deg, var(--color-primary), var(--color-primary-dark));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .nd-cta-body {
    font-size: 1.1rem;
    color: var(--color-ink-soft);
    line-height: 1.65;
    max-width: 40rem;
    margin: 0 0 2rem;
  }
  .nd-cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.75rem;
  }
  .nd-cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.9rem 1.5rem;
    border-radius: 9999px;
    background: var(--color-primary);
    color: #ffffff;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    box-shadow: 0 10px 28px rgb(15 118 110 / 0.26);
    transition: all 300ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nd-cta-btn-primary:hover {
    transform: translateY(-2px);
    background: var(--color-primary-dark);
    box-shadow: 0 16px 44px rgb(15 118 110 / 0.36);
  }
  .nd-cta-btn-primary svg { width: 1rem; height: 1rem; transition: transform 300ms; }
  .nd-cta-btn-primary:hover svg { transform: translateX(3px); }
  .nd-cta-btn-ghost {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 1.5rem;
    border-radius: 9999px;
    border: 1px solid rgb(15 118 110 / 0.28);
    color: var(--color-primary-dark);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: border-color 300ms, background 300ms;
  }
  .nd-cta-btn-ghost:hover {
    border-color: var(--color-primary);
    background: rgb(15 118 110 / 0.05);
  }

  .nd-cta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem 1.25rem;
    margin: 0;
    padding: 0;
  }
  @media (min-width: 640px) { .nd-cta-grid { grid-template-columns: repeat(4, 1fr); gap: 1.25rem; } }
  .nd-cta-stat { display: flex; flex-direction: column; gap: 0.35rem; }
  .nd-cta-stat-num {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-ink);
    font-variant-numeric: tabular-nums;
    margin: 0;
  }
  .nd-cta-stat-label {
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink-soft);
    margin: 0;
  }
</style>
