---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GradeReveal from "../../components/GradeReveal.astro";
import {
  getAllProducts,
  cleanCategorySlug,
  type Product,
} from "../../lib/data";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  // Astro 6: getStaticPaths is extracted and cannot see module-scope consts.
  // Define GRADE_ORDER inline.
  const GRADE_ORDER: Record<string, number> = { A: 5, B: 4, C: 3, D: 2, E: 1 };
  const all = await getAllProducts(1000);
  const targets = all.filter((p) => p.grade === "D" || p.grade === "E");

  const out: any[] = [];
  for (const target of targets) {
    const currentRank = GRADE_ORDER[target.grade!] || 0;
    const primaryCategoryRaw = (target.categories || []).find((c) => c && c.length > 3);
    if (!primaryCategoryRaw) continue;
    const cleanSlug = cleanCategorySlug(primaryCategoryRaw);
    const alternatives = all
      .filter(
        (p) =>
          p.slug !== target.slug &&
          p.grade &&
          (GRADE_ORDER[p.grade] || 0) > currentRank &&
          (p.categories || []).some((c) => cleanCategorySlug(c) === cleanSlug)
      )
      .slice(0, 5);

    if (alternatives.length === 0) continue;

    out.push({
      params: { slug: target.slug },
      props: { target, alternatives },
    });
  }
  return out;
}

const { target, alternatives } = Astro.props as { target: Product; alternatives: Product[] };

const title = `Alternatives to ${target.name} , better grades | NutriDécrypte`;
const description = `5 better-graded alternatives to ${target.name}${target.brand_slug ? ` (${target.brand_slug.replace(/-/g, " ")})` : ""}. Same category, higher A-E grade, independent ranking.`;
const canonicalUrl = siteConfig.url + `/alternatives/${target.slug}/`;

const breadcrumbs = [
  { name: "Home", url: siteConfig.url + "/" },
  { name: "Catalog", url: siteConfig.url + "/rankings/" },
  { name: target.name, url: siteConfig.url + `/product/${target.slug}/` },
  { name: "Alternatives", url: canonicalUrl },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Alternatives to ${target.name}`,
  numberOfItems: alternatives.length,
  itemListElement: alternatives.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: siteConfig.url + `/product/${p.slug}/`,
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  alternates={{ en: `/alternatives/${target.slug}/`, fr: `/fr/alternatives/${target.slug}/` }}
  jsonLd={[itemListJsonLd, breadcrumbJsonLd]}
>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-700 mb-2">Swap for better</p>
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4">
        Alternatives to <span class="text-stone-900">{target.name}</span>
      </h1>
      <div class="flex items-center gap-4 flex-wrap">
        {target.grade && <GradeReveal grade={target.grade} size="lg" animate={false} />}
        <p class="text-lg text-stone-700">
          Current grade <strong>{target.grade}</strong>{target.score_overall != null ? ` (${target.score_overall}/100)` : ""}.
          Here are {alternatives.length} better-graded product{alternatives.length > 1 ? "s" : ""} in the same category.
        </p>
      </div>
    </header>

    <aside data-speakable class="bg-stone-50 border-l-4 border-teal-600 rounded-r-xl p-6 mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-700 mb-3">TL;DR</p>
      <p class="text-base leading-relaxed text-stone-800">
        <strong>{target.name}</strong> is graded <strong>{target.grade}</strong> by NutriDécrypte.
        This page lists {alternatives.length} product{alternatives.length > 1 ? "s" : ""} from the same category with a better A to E grade, combining Nutri-Score, NOVA, EFSA additives, claims audit and density. Swap for a product that scores higher without changing your shopping habit.
      </p>
    </aside>

    <!-- Target recap -->
    <section class="mb-10 bg-red-50 border border-red-200 rounded-xl p-5">
      <p class="text-xs uppercase font-bold tracking-widest text-red-700 mb-3">Current product</p>
      <a href={`/product/${target.slug}/`} class="flex items-center gap-4 group">
        {target.image_url ? (
          <img src={target.image_url} alt="" class="w-20 h-20 object-contain bg-white rounded-lg" loading="lazy" width="80" height="80" />
        ) : (
          <div class="w-20 h-20 bg-white rounded-lg"></div>
        )}
        <div class="flex-1">
          <p class="font-bold text-stone-900 text-lg group-hover:text-teal-700">{target.name}</p>
          {target.brand_slug && (
            <p class="text-sm text-stone-600">{target.brand_slug.replace(/-/g, " ")}</p>
          )}
        </div>
        {target.grade && <GradeReveal grade={target.grade} size="lg" animate={false} />}
      </a>
    </section>

    <!-- Alternatives -->
    <section>
      <h2 class="text-2xl font-bold mb-6">Better alternatives</h2>
      <div class="grid gap-4">
        {alternatives.map((p, i) => (
          <a
            href={`/product/${p.slug}/`}
            class="flex items-center gap-4 bg-white border border-stone-200 rounded-xl p-5 hover:border-teal-400 hover:shadow-md transition"
          >
            <span class="text-3xl font-extrabold text-teal-700 w-10 text-center">#{i + 1}</span>
            {p.image_url ? (
              <img src={p.image_url} alt="" class="w-20 h-20 object-contain bg-stone-50 rounded flex-shrink-0" loading="lazy" width="80" height="80" />
            ) : (
              <div class="w-20 h-20 bg-stone-100 rounded flex-shrink-0"></div>
            )}
            <div class="flex-1 min-w-0">
              <p class="font-bold text-stone-900 text-lg leading-tight">{p.name}</p>
              {p.brand_slug && (
                <p class="text-sm text-stone-500">{p.brand_slug.replace(/-/g, " ")}</p>
              )}
              {p.score_overall != null && (
                <p class="text-xs text-stone-500 mt-1">Score : {p.score_overall}/100 · {(p.additives_tags || []).length} additifs</p>
              )}
            </div>
            {p.grade && <GradeReveal grade={p.grade} size="lg" animate={false} />}
          </a>
        ))}
      </div>
    </section>

    <footer class="mt-12 text-sm text-stone-600 text-center">
      <a href={`/fr/alternatives/${target.slug}/`} class="text-teal-700 underline">Version française</a>
    </footer>
  </section>
</BaseLayout>
