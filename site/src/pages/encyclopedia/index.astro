---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import TLDRBlock from "../../components/TLDRBlock.astro";
import { getAllAdditives, getAllProducts } from "../../lib/data";
import { jsonLdDataset, formatHumanDate, isoDate } from "../../utils/seo";
import { siteConfig } from "../../../site.config";

const additives = await getAllAdditives();
const allProducts = await getAllProducts(1000);

// Freshness: most recent additive review date (real DB field).
const lastReviewedIso = additives.reduce((max, a) => {
  const t = a.last_reviewed_at || "";
  return t && t > max ? t : max;
}, "");
const updatedHuman = formatHumanDate(lastReviewedIso || new Date(), "en");
const datasetModified = isoDate(lastReviewedIso || new Date());

// Compute usage count per additive (how many products contain it)
const usageMap = new Map<string, number>();
for (const p of allProducts) {
  for (const tag of (p.additives_tags || [])) {
    const lower = tag.toLowerCase();
    for (const a of additives) {
      if (lower.includes(a.e_number.toLowerCase()) || lower.endsWith(":" + a.slug)) {
        usageMap.set(a.slug, (usageMap.get(a.slug) || 0) + 1);
      }
    }
  }
}

const additivesWithUsage = additives.map((a) => ({ ...a, usage: usageMap.get(a.slug) || 0 }));

// Stats for the header summary
const stats = {
  total: additives.length,
  high: additives.filter((a) => a.risk_level === "high").length,
  medium: additives.filter((a) => a.risk_level === "medium").length,
  low: additives.filter((a) => a.risk_level === "low").length,
  controversial: additives.filter((a) => a.controversy).length,
  banned: additives.filter((a) => a.banned_in && a.banned_in.length > 0).length,
};

// Top 5 most-used additives
const mostUsed = [...additivesWithUsage].filter((a) => a.usage > 0).sort((x, y) => y.usage - x.usage).slice(0, 8);

// Group by risk
const groups: Record<string, typeof additivesWithUsage> = {
  high: [],
  medium: [],
  low: [],
  unknown: [],
};
for (const a of additivesWithUsage) {
  const level = (a.risk_level || "unknown") as keyof typeof groups;
  if (!groups[level]) groups[level] = [];
  groups[level].push(a);
}

const groupOrder: Array<keyof typeof groups> = ["high", "medium", "low", "unknown"];
const labels: Record<string, string> = {
  high: "High risk",
  medium: "Medium risk",
  low: "Low risk",
  unknown: "Unknown",
};
const accents: Record<string, string> = {
  high: "border-red-400 bg-red-50",
  medium: "border-amber-400 bg-amber-50",
  low: "border-emerald-400 bg-emerald-50",
  unknown: "border-stone-300 bg-stone-50",
};

const breadcrumbs = [
  { name: "Home", url: siteConfig.url + "/" },
  { name: "Additives encyclopedia", url: siteConfig.url + "/encyclopedia/" },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

// First-party Dataset: the additives risk registry. Every count is shown below.
const datasetJsonLd = jsonLdDataset({
  name: "NutriDécrypte Food Additives Risk Registry",
  description: `${additives.length} food additives (E-numbers) classified by risk level using EFSA and ANSES sources: ${stats.high} high risk, ${stats.medium} medium risk, ${stats.low} low risk, ${stats.controversial} controversial, ${stats.banned} EU-restricted.`,
  url: siteConfig.url + "/encyclopedia/",
  dateModified: datasetModified,
  variableMeasured: [
    "E-number",
    "Additive risk level",
    "Controversy flag",
    "EU restriction status",
    "Catalog usage count",
  ],
  keywords: ["food additives", "E-numbers", "EFSA", "ANSES", "additive risk"],
});

const title = `Food additives encyclopedia , ${additives.length} E-numbers decoded | NutriDécrypte`;
const description = `${additives.length} food additives explained, classified by EFSA and ANSES risk level. High-risk E-numbers, controversial additives, and which products contain them.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + "/encyclopedia/"}
  alternates={{ en: "/encyclopedia/", fr: "/fr/encyclopedie/" }}
  jsonLd={[breadcrumbJsonLd, datasetJsonLd]}
>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-700 mb-2">Encyclopedia</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Food additives encyclopedia</h1>
      <p class="text-lg text-stone-700 max-w-3xl mb-6">
        {additives.length} E-numbers decoded, classified by EFSA + ANSES risk level. Learn what each additive is, whether it is controversial, and which products of our catalog contain it.
      </p>

      <TLDRBlock label="In short">
        Our additives registry covers <strong>{additives.length} E-numbers</strong>, each rated by risk:
        <strong>{stats.high}</strong> high risk, <strong>{stats.medium}</strong> medium risk and
        <strong>{stats.low}</strong> low risk, including <strong>{stats.controversial}</strong> controversial
        and <strong>{stats.banned}</strong> restricted in the EU. Risk levels are sourced from EFSA and ANSES.
        Registry last reviewed {updatedHuman}.
      </TLDRBlock>

      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 max-w-3xl">
        <div class="px-3 py-2 rounded-lg bg-red-50 border border-red-200 text-center">
          <p class="text-2xl font-extrabold text-red-700">{stats.high}</p>
          <p class="text-[11px] uppercase tracking-wide text-red-700 font-semibold">High risk</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-center">
          <p class="text-2xl font-extrabold text-amber-700">{stats.medium}</p>
          <p class="text-[11px] uppercase tracking-wide text-amber-700 font-semibold">Medium risk</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-emerald-50 border border-emerald-200 text-center">
          <p class="text-2xl font-extrabold text-emerald-700">{stats.low}</p>
          <p class="text-[11px] uppercase tracking-wide text-emerald-700 font-semibold">Low risk</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-stone-100 border border-stone-200 text-center">
          <p class="text-2xl font-extrabold text-stone-700">{stats.controversial}</p>
          <p class="text-[11px] uppercase tracking-wide text-stone-600 font-semibold">Controversial</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-stone-100 border border-stone-200 text-center">
          <p class="text-2xl font-extrabold text-stone-700">{stats.banned}</p>
          <p class="text-[11px] uppercase tracking-wide text-stone-600 font-semibold">EU restricted</p>
        </div>
      </div>

      <div class="mt-6 max-w-xl">
        <input
          type="search"
          id="additive-search"
          placeholder="Search by E-number or name (e.g. e211, sodium benzoate)"
          class="w-full px-4 py-2.5 border border-stone-300 rounded-lg text-sm focus:outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-100"
          aria-label="Search additives"
        />
      </div>
    </header>

    {mostUsed.length > 0 && (
      <section class="mb-10 p-5 bg-teal-50 border border-teal-200 rounded-xl">
        <h2 class="text-lg font-bold text-teal-900 mb-3">Most common additives in our catalog</h2>
        <p class="text-sm text-teal-800 mb-4">The E-numbers detected most often across the {allProducts.length}+ products we have decoded so far. Click to read the full risk profile.</p>
        <div class="flex flex-wrap gap-2">
          {mostUsed.map((a) => (
            <a href={`/encyclopedia/${a.slug}/`} class="inline-flex items-center gap-2 bg-white border border-teal-300 rounded-full px-3 py-1.5 text-sm hover:border-teal-500 transition">
              <span class="font-mono font-bold text-teal-800">{a.e_number}</span>
              <span class="text-stone-700">{a.name_en || a.name_fr}</span>
              <span class="text-xs text-stone-500">({a.usage}×)</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {groupOrder.map((g) => {
      const arr = groups[g] || [];
      if (arr.length === 0) return null;
      return (
        <section class={`mb-10 border-l-4 rounded-r-xl p-6 ${accents[g]}`}>
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-2xl font-bold">{labels[g]}</h2>
            <span class="text-sm text-stone-600">{arr.length} additive{arr.length > 1 ? "s" : ""}</span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 additive-grid">
            {arr.map((a) => (
              <a
                href={`/encyclopedia/${a.slug}/`}
                data-search={`${a.e_number} ${a.name_en || ""} ${a.name_fr || ""} ${a.category || ""}`.toLowerCase()}
                class="additive-card block bg-white border border-stone-200 rounded-lg p-4 hover:border-teal-400 hover:shadow-sm transition"
              >
                <p class="font-mono text-teal-700 text-xs mb-1">{a.e_number}</p>
                <p class="font-medium text-stone-900 mb-1">{a.name_en || a.name_fr}</p>
                {a.category && (
                  <p class="text-xs text-stone-500">{a.category}</p>
                )}
                <div class="flex items-center gap-2 mt-2">
                  {a.controversy && (
                    <span class="text-[11px] text-amber-700 font-semibold">Controversial</span>
                  )}
                  {a.usage > 0 && (
                    <span class="text-[11px] text-stone-500">{a.usage} product{a.usage > 1 ? "s" : ""}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <footer class="mt-12 text-sm text-stone-600 text-center space-y-1">
      <p>
        Registry: {additives.length} E-numbers, risk levels from
        <a href="https://www.efsa.europa.eu/en/topics/topic/food-additives" rel="external nofollow noopener" class="text-teal-700 underline">EFSA</a>
        and <a href="https://www.anses.fr" rel="external nofollow noopener" class="text-teal-700 underline">ANSES</a>,
        last reviewed <time datetime={datasetModified}>{updatedHuman}</time>.
      </p>
      <p><a href="/fr/encyclopedie/" class="text-teal-700 underline">Version française</a></p>
    </footer>
  </section>
</BaseLayout>

<script is:inline>
  const search = document.getElementById("additive-search");
  if (search) {
    search.addEventListener("input", (e) => {
      const q = e.target.value.toLowerCase().trim();
      document.querySelectorAll(".additive-card").forEach((card) => {
        const data = card.getAttribute("data-search") || "";
        card.style.display = !q || data.includes(q) ? "" : "none";
      });
    });
  }
</script>
