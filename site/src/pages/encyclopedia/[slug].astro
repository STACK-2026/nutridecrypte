---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import {
  getAllAdditives,
  getAllProducts,
  type Additive,
  type Product,
} from "../../lib/data";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const additives = await getAllAdditives();
  const products = await getAllProducts(1000);
  return additives
    .filter((a) => a.slug)
    .map((a) => {
      // Find products containing this additive
      const matches = products
        .filter((p) =>
          (p.additives_tags || []).some((tag) => {
            const lower = tag.toLowerCase();
            return lower.includes(a.e_number.toLowerCase()) || lower.endsWith(":" + a.slug);
          })
        )
        .slice(0, 10);
      return {
        params: { slug: a.slug },
        props: { additive: a, products: matches },
      };
    });
}

const { additive, products } = Astro.props as { additive: Additive; products: Product[] };

const riskColor: Record<string, string> = {
  low: "bg-emerald-50 text-emerald-800 border-emerald-200",
  medium: "bg-amber-50 text-amber-800 border-amber-200",
  high: "bg-red-50 text-red-800 border-red-200",
  unknown: "bg-stone-50 text-stone-700 border-stone-200",
};

const riskLabel: Record<string, string> = {
  low: "Low risk",
  medium: "Medium risk",
  high: "High risk",
  unknown: "Unknown",
};

const name = additive.name_en || additive.name_fr || additive.e_number;

const breadcrumbs = [
  { name: "Home", url: siteConfig.url + "/" },
  { name: "Additives", url: siteConfig.url + "/encyclopedia/" },
  { name: `${additive.e_number} , ${name}`, url: siteConfig.url + `/encyclopedia/${additive.slug}/` },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const definedTermJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: `${additive.e_number} , ${name}`,
  alternateName: additive.e_number,
  description: additive.summary_en || additive.summary_fr || `Food additive ${additive.e_number}`,
  url: siteConfig.url + `/encyclopedia/${additive.slug}/`,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "EU Food Additives Registry",
    url: "https://www.efsa.europa.eu/",
  },
};

const title = `${additive.e_number} , ${name} | NutriDécrypte Encyclopedia`;
const description = (additive.summary_en || additive.summary_fr || `Food additive ${additive.e_number}`).slice(0, 155);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + `/encyclopedia/${additive.slug}/`}
  alternates={{ en: `/encyclopedia/${additive.slug}/`, fr: `/fr/encyclopedie/${additive.slug}/` }}
  jsonLd={[definedTermJsonLd, breadcrumbJsonLd]}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-mono text-teal-700 mb-2">{additive.e_number}</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{additive.e_number} , {name}</h1>
      <div class="flex flex-wrap gap-2 items-center">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold border ${riskColor[additive.risk_level] || riskColor.unknown}`}>
          {riskLabel[additive.risk_level] || "Unknown"}
        </span>
        {additive.controversy && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-800 border border-amber-200">
            Controversial
          </span>
        )}
        {additive.category && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">
            {additive.category}
          </span>
        )}
      </div>
    </header>

    <aside data-speakable class="bg-stone-50 border-l-4 border-teal-600 rounded-r-xl p-6 mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-700 mb-3">TL;DR</p>
      <p class="text-base leading-relaxed text-stone-800">
        <strong>{additive.e_number}</strong> ({name}) is classified as <strong>{riskLabel[additive.risk_level].toLowerCase()}</strong> in the NutriDécrypte encyclopedia.
        {additive.controversy ? " It is flagged as controversial by independent reviewers." : ""}
        {additive.banned_in && additive.banned_in.length ? ` Banned or restricted in : ${additive.banned_in.join(", ")}.` : ""}
        Risk levels follow the European Food Safety Authority (EFSA) and ANSES reviews, published on the official registries.
      </p>
    </aside>

    {(additive.summary_en || additive.summary_fr) && (
      <section class="prose max-w-none mb-10">
        <h2>Why this classification</h2>
        <p class="text-base leading-relaxed text-stone-800">
          {additive.summary_en || additive.summary_fr}
        </p>
      </section>
    )}

    {additive.banned_in && additive.banned_in.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Banned or restricted in</h2>
        <ul class="flex flex-wrap gap-2">
          {additive.banned_in.map((c) => (
            <li class="px-3 py-1.5 rounded-full bg-red-50 text-red-800 border border-red-200 text-sm">
              {c}
            </li>
          ))}
        </ul>
      </section>
    )}

    {additive.efsa_opinion_url && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Official source</h2>
        <a
          href={additive.efsa_opinion_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-teal-700 hover:text-teal-900 underline font-medium"
        >
          EFSA opinion on {additive.e_number} &rsaquo;
        </a>
      </section>
    )}

    {products.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Products containing {additive.e_number}</h2>
        <div class="grid gap-3">
          {products.map((p) => (
            <a
              href={`/product/${p.slug}/`}
              class="flex items-center gap-3 bg-white border border-stone-200 rounded-lg p-3 hover:border-teal-400 transition"
            >
              {p.image_url ? (
                <img src={p.image_url} alt="" class="w-12 h-12 object-contain bg-stone-50 rounded flex-shrink-0" loading="lazy" width="48" height="48" />
              ) : (
                <div class="w-12 h-12 bg-stone-100 rounded flex-shrink-0"></div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-medium text-stone-900 truncate">{p.name}</p>
                {p.brand_slug && (
                  <p class="text-xs text-stone-500 truncate">{p.brand_slug.replace(/-/g, " ")}</p>
                )}
              </div>
              {p.grade && (
                <span
                  class={`text-sm font-extrabold px-2.5 py-1 rounded text-white`}
                  style={`background: var(--grade-${p.grade.toLowerCase()})`}
                >
                  {p.grade}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <footer class="mt-12 p-6 bg-teal-50 border border-teal-200 rounded-xl text-center">
      <p class="text-sm text-stone-700">
        <a href="/encyclopedia/" class="text-teal-800 font-medium underline">
          All additives &rsaquo;
        </a>
        {" · "}
        <a href={`/fr/encyclopedie/${additive.slug}/`} class="text-teal-800 underline">
          Version française
        </a>
      </p>
    </footer>
  </article>
</BaseLayout>
