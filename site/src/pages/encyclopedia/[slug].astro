---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import {
  getAllAdditives,
  getAllProducts,
  type Additive,
  type Product,
} from "../../lib/data";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const additives = await getAllAdditives();
  const products = await getAllProducts(1000);
  return additives
    .filter((a) => a.slug)
    .map((a) => {
      // Find products containing this additive
      const matches = products
        .filter((p) =>
          (p.additives_tags || []).some((tag) => {
            const lower = tag.toLowerCase();
            return lower.includes(a.e_number.toLowerCase()) || lower.endsWith(":" + a.slug);
          })
        )
        .slice(0, 10);
      // Related additives: same category, different slug, top 5
      const related = a.category
        ? additives.filter((x) => x.slug && x.slug !== a.slug && x.category === a.category).slice(0, 5)
        : [];
      return {
        params: { slug: a.slug },
        props: { additive: a, products: matches, related },
      };
    });
}

const { additive, products, related } = Astro.props as { additive: Additive; products: Product[]; related: Additive[] };

// Category-aware "common uses" copy (food technology context, not auto-generated boilerplate)
const categoryUses: Record<string, string> = {
  preservative: "preserving products against mould, yeast and bacterial growth, especially in soft drinks, sauces, pickles and sliced bread",
  antioxidant: "preventing fats and oils from oxidising and going rancid, common in margarine, biscuits, snack foods and cured meat",
  colour: "restoring or enhancing the colour lost during industrial processing, mainly in confectionery, sodas, sauces and convenience meals",
  emulsifier: "binding water and oil together to keep texture stable in margarine, ice cream, mayonnaise, ready meals and ultra-processed pastries",
  thickener: "increasing viscosity in dairy desserts, sauces, soups and plant-based drinks",
  stabiliser: "preventing ingredients from separating during shelf life, common in dressings, dairy desserts, ready-meals and beverages",
  sweetener: "replacing sugar in low-calorie drinks, dairy desserts, chewing gum and tabletop sweeteners",
  "flavour enhancer": "amplifying savoury or umami taste in soups, snacks, instant noodles, sauces and processed meat",
  acidulant: "adjusting the acidity to a target pH, used in sodas, candies, jams and dairy desserts",
  "anti-caking agent": "stopping powders and granules from clumping, common in salt, spice mixes, grated cheese and powdered drinks",
};
const lcCategory = (additive.category || "").toLowerCase();
const usesCopy = Object.keys(categoryUses).find((k) => lcCategory.includes(k))
  ? categoryUses[Object.keys(categoryUses).find((k) => lcCategory.includes(k)) as string]
  : "various technological roles in industrial food formulations";

const riskColor: Record<string, string> = {
  low: "bg-emerald-50 text-emerald-800 border-emerald-200",
  medium: "bg-amber-50 text-amber-800 border-amber-200",
  high: "bg-red-50 text-red-800 border-red-200",
  unknown: "bg-stone-50 text-stone-700 border-stone-200",
};

const riskLabel: Record<string, string> = {
  low: "Low risk",
  medium: "Medium risk",
  high: "High risk",
  unknown: "Unknown",
};

const name = additive.name_en || additive.name_fr || additive.e_number;

const breadcrumbs = [
  { name: "Home", url: siteConfig.url + "/" },
  { name: "Additives", url: siteConfig.url + "/encyclopedia/" },
  { name: `${additive.e_number} , ${name}`, url: siteConfig.url + `/encyclopedia/${additive.slug}/` },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const definedTermJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: `${additive.e_number} , ${name}`,
  alternateName: additive.e_number,
  description: additive.summary_en || additive.summary_fr || `Food additive ${additive.e_number}`,
  url: siteConfig.url + `/encyclopedia/${additive.slug}/`,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "EU Food Additives Registry",
    url: "https://www.efsa.europa.eu/",
  },
};

const productCount = products.length;
const inUseLabel = productCount > 0 ? `Found in ${productCount} product${productCount > 1 ? "s" : ""}.` : "";
const title = `${name} (${additive.e_number}) , ${riskLabel[additive.risk_level || "unknown"]} food additive | NutriDécrypte`;
const summaryRaw = (additive.summary_en || additive.summary_fr || `Food additive ${additive.e_number} (${name}). EFSA risk: ${riskLabel[additive.risk_level || "unknown"]}.`).trim();
const summaryClean = summaryRaw.endsWith(".") ? summaryRaw : summaryRaw + ".";
const description = `${name} (${additive.e_number}): ${summaryClean}${inUseLabel ? " " + inUseLabel : ""}`.slice(0, 158);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + `/encyclopedia/${additive.slug}/`}
  alternates={{ en: `/encyclopedia/${additive.slug}/`, fr: `/fr/encyclopedie/${additive.slug}/` }}
  jsonLd={[definedTermJsonLd, breadcrumbJsonLd]}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-mono text-teal-700 mb-2">{additive.e_number}</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{additive.e_number} , {name}</h1>
      <div class="flex flex-wrap gap-2 items-center">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold border ${riskColor[additive.risk_level] || riskColor.unknown}`}>
          {riskLabel[additive.risk_level] || "Unknown"}
        </span>
        {additive.controversy && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-800 border border-amber-200">
            Controversial
          </span>
        )}
        {additive.category && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">
            {additive.category}
          </span>
        )}
      </div>
    </header>

    <aside data-speakable class="bg-stone-50 border-l-4 border-teal-600 rounded-r-xl p-6 mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-700 mb-3">TL;DR</p>
      <p class="text-base leading-relaxed text-stone-800">
        <strong>{additive.e_number}</strong> ({name}) is classified as <strong>{riskLabel[additive.risk_level].toLowerCase()}</strong> in the NutriDécrypte encyclopedia.
        {additive.controversy ? " It is flagged as controversial by independent reviewers." : ""}
        {additive.banned_in && additive.banned_in.length ? ` Banned or restricted in : ${additive.banned_in.join(", ")}.` : ""}
        Risk levels follow the European Food Safety Authority (EFSA) and ANSES reviews, published on the official registries.
      </p>
    </aside>

    {(additive.summary_en || additive.summary_fr) && (
      <section class="prose max-w-none mb-10">
        <h2>Why this classification</h2>
        <p class="text-base leading-relaxed text-stone-800">
          {additive.summary_en || additive.summary_fr}
        </p>
      </section>
    )}

    {additive.banned_in && additive.banned_in.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Banned or restricted in</h2>
        <ul class="flex flex-wrap gap-2">
          {additive.banned_in.map((c) => (
            <li class="px-3 py-1.5 rounded-full bg-red-50 text-red-800 border border-red-200 text-sm">
              {c}
            </li>
          ))}
        </ul>
      </section>
    )}

    {additive.efsa_opinion_url && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Official source</h2>
        <a
          href={additive.efsa_opinion_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-teal-700 hover:text-teal-900 underline font-medium"
        >
          EFSA opinion on {additive.e_number} &rsaquo;
        </a>
      </section>
    )}

    {products.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Products containing {additive.e_number}</h2>
        <div class="grid gap-3">
          {products.map((p) => (
            <a
              href={`/product/${p.slug}/`}
              class="flex items-center gap-3 bg-white border border-stone-200 rounded-lg p-3 hover:border-teal-400 transition"
            >
              {p.image_url ? (
                <img src={p.image_url} alt="" class="w-12 h-12 object-contain bg-stone-50 rounded flex-shrink-0" loading="lazy" width="48" height="48" />
              ) : (
                <div class="w-12 h-12 bg-stone-100 rounded flex-shrink-0"></div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-medium text-stone-900 truncate">{p.name}</p>
                {p.brand_slug && (
                  <p class="text-xs text-stone-500 truncate">{p.brand_slug.replace(/-/g, " ")}</p>
                )}
              </div>
              {p.grade && (
                <span
                  class={`text-sm font-extrabold px-2.5 py-1 rounded text-white`}
                  style={`background: var(--grade-${p.grade.toLowerCase()})`}
                >
                  {p.grade}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mb-10 prose max-w-none">
      <h2>Common uses in industrial food</h2>
      <p>
        {name} ({additive.e_number}) is used by food manufacturers for {usesCopy}.
        It is most often listed in the ingredient panel as <strong>{additive.e_number}</strong>, <strong>{name}</strong>, or under one of its trade names.
        On a NutriDécrypte product page, this additive contributes to the <em>additives axis</em> (20% of the overall A to E grade), and triggers a label warning when its EFSA risk level is medium or high.
      </p>
      <p>
        If you want to limit your exposure to this additive, the simplest tactic is to read the ingredients list (not just the front-of-pack), and to favour products graded A or B in our <a href="/rankings/">independent catalog</a>. Less processed, NOVA-1 or NOVA-2 categories rarely contain it.
      </p>
    </section>

    {related.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Related additives in the same family</h2>
        <p class="text-stone-700 mb-4">
          Other E-numbers classified as <strong>{additive.category}</strong> in the EU food additives registry. Their risk profile and behaviour on a label are often similar.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {related.map((r) => (
            <li>
              <a href={`/encyclopedia/${r.slug}/`} class="flex items-center justify-between bg-white border border-stone-200 rounded-lg px-4 py-2 hover:border-teal-400 transition">
                <span><strong>{r.e_number}</strong> , {r.name_en || r.name_fr || r.e_number}</span>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${riskColor[r.risk_level || "unknown"]}`}>
                  {riskLabel[r.risk_level || "unknown"]}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mb-10 prose max-w-none">
      <h2>Frequently asked questions</h2>
      <h3>Is {additive.e_number} ({name}) safe?</h3>
      <p>
        EFSA classifies the risk level of {additive.e_number} as <strong>{riskLabel[additive.risk_level || "unknown"].toLowerCase()}</strong> in its latest review.
        {additive.controversy ? " It is also flagged as controversial by independent toxicology reviewers, meaning the scientific consensus is contested." : ""}
        {additive.banned_in && additive.banned_in.length ? ` Several jurisdictions have restricted or banned its use, including: ${additive.banned_in.join(", ")}.` : ""}
        Always read the latest official opinion before drawing conclusions for your own diet, and consult a registered dietitian for medical questions.
      </p>
      <h3>What is {additive.e_number} typically used for?</h3>
      <p>
        Food manufacturers use {name} primarily for {usesCopy}. You will most often find it in ultra-processed foods (NOVA group 4) and rarely in unprocessed or minimally processed products (NOVA 1 or 2).
      </p>
      <h3>How can I avoid {additive.e_number} on a label?</h3>
      <p>
        Look for the code <strong>{additive.e_number}</strong> or its full name <strong>{name}</strong> in the ingredients list, usually printed in small font on the back of the pack. Cooking from raw ingredients, choosing NOVA-1 or NOVA-2 alternatives, and using the <a href="/rankings/">NutriDécrypte rankings</a> to filter by grade A or B are the three most reliable strategies.
      </p>
      {additive.efsa_opinion_url && (
        <>
          <h3>Where can I read the official EFSA opinion?</h3>
          <p>
            The European Food Safety Authority publishes its scientific opinion on {additive.e_number} at <a href={additive.efsa_opinion_url} target="_blank" rel="noopener noreferrer">{additive.efsa_opinion_url}</a>. ANSES, France's national agency, regularly updates its own positions on the same molecule.
          </p>
        </>
      )}
    </section>

    <footer class="mt-12 p-6 bg-teal-50 border border-teal-200 rounded-xl text-center">
      <p class="text-sm text-stone-700">
        <a href="/encyclopedia/" class="text-teal-800 font-medium underline">
          All additives &rsaquo;
        </a>
        {" · "}
        <a href={`/fr/encyclopedie/${additive.slug}/`} class="text-teal-800 underline">
          Version française
        </a>
      </p>
    </footer>
  </article>
</BaseLayout>
