---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../../site.config";
import { tr, t, getLocale, localeUrl } from "../i18n/t";

const locale = getLocale(Astro.url);
---

<BaseLayout
  title={`${t(tr.notFound.title, locale)} | ${siteConfig.name}`}
  description={t(tr.notFound.body, locale)}
  noIndex
>
  <section class="notfound">
    <div class="notfound-decor" aria-hidden="true">
      <svg viewBox="0 0 140 100" fill="none">
        <defs>
          <linearGradient id="labelGrad" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#0f766e" stop-opacity="0.14"/>
            <stop offset="100%" stop-color="#065f46" stop-opacity="0.06"/>
          </linearGradient>
        </defs>
        <!-- Label rectangle -->
        <rect x="30" y="20" width="60" height="60" rx="3" fill="url(#labelGrad)" stroke="#0f766e" stroke-width="2"/>
        <line x1="38" y1="32" x2="78" y2="32" stroke="#0f766e" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="38" y1="40" x2="72" y2="40" stroke="#0f766e" stroke-width="1.5" stroke-linecap="round" opacity="0.6"/>
        <line x1="38" y1="48" x2="68" y2="48" stroke="#0f766e" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <line x1="38" y1="56" x2="64" y2="56" stroke="#0f766e" stroke-width="1.5" stroke-linecap="round" opacity="0.4"/>
        <line x1="38" y1="64" x2="60" y2="64" stroke="#0f766e" stroke-width="1.5" stroke-linecap="round" opacity="0.3"/>
        <!-- Magnifier -->
        <circle cx="98" cy="55" r="18" fill="#ffffff" stroke="#f59e0b" stroke-width="3"/>
        <line x1="111" y1="69" x2="125" y2="83" stroke="#f59e0b" stroke-width="4" stroke-linecap="round"/>
        <text x="98" y="62" text-anchor="middle" font-family="system-ui" font-size="18" font-weight="900" fill="#dc2626">?</text>
      </svg>
    </div>

    <div class="notfound-inner">
      <p class="code" aria-hidden="true">{t(tr.notFound.code, locale)}</p>
      <h1>{t(tr.notFound.title, locale)}</h1>
      <p class="lede">{t(tr.notFound.body, locale)}</p>

      <div class="notfound-ctas">
        <a href={localeUrl("/", locale)} class="btn-primary">
          {t(tr.notFound.home, locale)}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={localeUrl("/rankings", locale)} class="btn-secondary">{t(tr.notFound.score, locale)}</a>
      </div>

      <div class="notfound-links">
        <p class="links-title">{t(tr.notFound.popular, locale)}</p>
        <ul>
          <li><a href={localeUrl("/rankings", locale)}><span class="grade grade-sm grade-a">A</span> {t(tr.nav.rankings, locale)}</a></li>
          <li><a href={localeUrl("/compare", locale)}><span class="grade grade-sm grade-b">B</span> {t(tr.nav.compare, locale)}</a></li>
          <li><a href={localeUrl("/encyclopedia", locale)}><span class="grade grade-sm grade-c">C</span> {t(tr.nav.encyclopedia, locale)}</a></li>
          <li><a href={localeUrl("/methodology", locale)}><span class="grade grade-sm grade-d">D</span> {t(tr.nav.methodology, locale)}</a></li>
          <li><a href={localeUrl("/blog", locale)}><span class="grade grade-sm grade-e">E</span> {t(tr.nav.blog, locale)}</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    padding: 5rem 1rem 6rem;
    background: linear-gradient(180deg, var(--color-bg-soft) 0%, #ffffff 60%);
    min-height: 70vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }
  .notfound-decor {
    position: absolute;
    top: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 180px;
    pointer-events: none;
    opacity: 0.9;
  }
  .notfound-inner {
    max-width: 44rem;
    margin: 7rem auto 0;
    text-align: center;
    position: relative;
  }
  .code {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 12vw, 7.5rem);
    font-weight: 900;
    line-height: 0.95;
    margin: 0 0 0.5rem;
    background: linear-gradient(135deg, rgb(15 118 110 / 0.9), rgb(6 95 70 / 0.4));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: -0.04em;
  }
  .notfound h1 { margin-bottom: 1rem; }
  .lede {
    color: var(--color-ink-soft);
    font-size: 1.1rem;
    max-width: 34rem;
    margin: 0 auto 2rem;
  }
  .notfound-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }
  .notfound-links {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.75rem 2rem;
    text-align: left;
    box-shadow: var(--shadow-card);
  }
  .links-title {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 800;
    color: var(--color-ink-soft);
    margin-bottom: 1rem;
  }
  .notfound-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.4rem;
  }
  @media (min-width: 640px) {
    .notfound-links ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .notfound-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.4rem;
    color: var(--color-ink);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    border-radius: 0.5rem;
    transition: all 200ms ease;
  }
  .notfound-links a:hover {
    background: var(--color-bg-soft);
    color: var(--color-primary-dark);
    transform: translateX(2px);
  }
</style>
