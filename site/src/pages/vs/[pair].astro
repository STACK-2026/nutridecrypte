---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import GradeReveal from "../../components/GradeReveal.astro";
import { getAllProducts, pickVerdict, type Product } from "../../lib/data";
import { siteConfig } from "../../../site.config";

export async function getStaticPaths() {
  const all = await getAllProducts(1000);
  const top = all
    .filter((p) => p.slug && p.score_overall != null)
    .slice(0, 20);

  const seen = new Set<string>();
  const pairs: Array<{ a: Product; b: Product; key: string }> = [];
  for (let i = 0; i < top.length; i++) {
    for (let j = i + 1; j < top.length; j++) {
      const [a, b] = top[i].slug < top[j].slug ? [top[i], top[j]] : [top[j], top[i]];
      const key = a.slug + "-vs-" + b.slug;
      if (seen.has(key)) continue;
      seen.add(key);
      pairs.push({ a, b, key });
      if (pairs.length >= 30) break;
    }
    if (pairs.length >= 30) break;
  }

  return pairs.map((p) => ({
    params: { pair: p.key },
    props: { a: p.a, b: p.b },
  }));
}

const { a, b } = Astro.props as { a: Product; b: Product };

const aScore = a.score_overall || 0;
const bScore = b.score_overall || 0;
const winner: Product | null = aScore === bScore ? null : aScore > bScore ? a : b;
const loser: Product | null = winner === null ? null : winner === a ? b : a;

const subScores = [
  { label: "Nutri-Score", aVal: a.score_nutri, bVal: b.score_nutri },
  { label: "NOVA", aVal: a.score_nova, bVal: b.score_nova },
  { label: "Additifs", aVal: a.score_additives, bVal: b.score_additives },
  { label: "Allegations", aVal: a.score_claims, bVal: b.score_claims },
  { label: "Densite", aVal: a.score_density, bVal: b.score_density },
];

const verdictEn = winner
  ? winner.name + " wins against " + (loser as Product).name + " with an overall score of " + winner.score_overall + "/100 versus " + (loser as Product).score_overall + "/100. " + pickVerdict(winner, "en")
  : a.name + " and " + b.name + " tie with identical overall scores.";

const verdictFr = winner
  ? winner.name + " bat " + (loser as Product).name + " avec un score global de " + winner.score_overall + "/100 contre " + (loser as Product).score_overall + "/100. " + pickVerdict(winner, "fr")
  : a.name + " et " + b.name + " font match nul avec des scores globaux identiques.";

const title = a.name + " vs " + b.name + " , side by side | NutriDecrypte";
const description = verdictEn.slice(0, 155);
const canonicalUrl = siteConfig.url + "/vs/" + a.slug + "-vs-" + b.slug + "/";

const breadcrumbs = [
  { name: "Home", url: siteConfig.url + "/" },
  { name: "Compare", url: siteConfig.url + "/compare/" },
  { name: a.name + " vs " + b.name, url: canonicalUrl },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((c, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: c.name,
    item: c.url,
  })),
};

const items = [a, b];
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={canonicalUrl}
  jsonLd={breadcrumbJsonLd}
  alternates={{ en: "/vs/" + a.slug + "-vs-" + b.slug + "/", fr: "/fr/vs/" + a.slug + "-vs-" + b.slug + "/" }}
>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-700 mb-2">Head to head</p>
      <h1 class="text-3xl md:text-5xl font-extrabold leading-tight mb-4">
        {a.name} <span class="text-teal-600">vs</span> {b.name}
      </h1>
    </header>

    <aside data-speakable class="bg-stone-50 border-l-4 border-teal-600 rounded-r-xl p-6 mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-700 mb-3">Verdict</p>
      <p class="text-base leading-relaxed text-stone-800 mb-3">{verdictFr}</p>
      <details class="text-sm text-stone-600">
        <summary class="cursor-pointer font-medium">English verdict</summary>
        <p class="mt-2">{verdictEn}</p>
      </details>
    </aside>

    <div class="grid md:grid-cols-2 gap-4 mb-10">
      {items.map((p) => (
        <a
          href={"/product/" + p.slug + "/"}
          class={"bg-white border rounded-xl p-6 transition hover:shadow-md " + (winner === p ? "border-teal-500 ring-2 ring-teal-100" : "border-stone-200")}
        >
          {winner === p ? (
            <p class="text-xs uppercase font-bold tracking-widest text-teal-700 mb-2">Winner</p>
          ) : null}
          <div class="flex items-center gap-4 mb-4">
            {p.image_url ? (
              <img src={p.image_url} alt="" class="w-16 h-16 object-contain bg-stone-50 rounded" loading="lazy" width="64" height="64" />
            ) : (
              <div class="w-16 h-16 bg-stone-100 rounded"></div>
            )}
            <div class="flex-1">
              <h2 class="font-bold text-lg text-stone-900 leading-tight">{p.name}</h2>
              {p.brand_slug ? (
                <p class="text-sm text-stone-500">{p.brand_slug.split("-").join(" ")}</p>
              ) : null}
            </div>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              {p.grade ? <GradeReveal grade={p.grade} size="lg" animate={false} /> : null}
              <div>
                <p class="text-2xl font-extrabold text-stone-900">{p.score_overall ?? "?"}</p>
                <p class="text-xs text-stone-500 uppercase">Score sur 100</p>
              </div>
            </div>
            <span class="text-xs text-stone-500">{(p.additives_tags || []).length} additifs</span>
          </div>
        </a>
      ))}
    </div>

    <section class="mb-10">
      <h2 class="text-xl font-bold mb-4">Comparaison axe par axe</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="text-stone-500">
            <tr>
              <th class="text-left font-medium px-4 py-2">Axe</th>
              <th class="text-right font-medium px-4 py-2">{a.name}</th>
              <th class="text-right font-medium px-4 py-2">{b.name}</th>
            </tr>
          </thead>
          <tbody>
            {subScores.map((s) => {
              const aWins = (s.aVal || 0) > (s.bVal || 0);
              const bWins = (s.bVal || 0) > (s.aVal || 0);
              return (
                <tr class="border-t border-stone-100">
                  <td class="px-4 py-3 font-medium">{s.label}</td>
                  <td class={"px-4 py-3 text-right font-mono " + (aWins ? "text-teal-700 font-bold" : "text-stone-700")}>
                    {s.aVal != null ? s.aVal + " sur 100" : "-"}
                  </td>
                  <td class={"px-4 py-3 text-right font-mono " + (bWins ? "text-teal-700 font-bold" : "text-stone-700")}>
                    {s.bVal != null ? s.bVal + " sur 100" : "-"}
                  </td>
                </tr>
              );
            })}
            <tr class="border-t-2 border-stone-200 bg-stone-50">
              <td class="px-4 py-3 font-bold">Score global</td>
              <td class={"px-4 py-3 text-right font-mono font-bold " + (aScore > bScore ? "text-teal-700" : "text-stone-700")}>
                {aScore + " sur 100"}
              </td>
              <td class={"px-4 py-3 text-right font-mono font-bold " + (bScore > aScore ? "text-teal-700" : "text-stone-700")}>
                {bScore + " sur 100"}
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-10 grid md:grid-cols-2 gap-4">
      {items.map((p) => (
        <div class="bg-white border border-stone-200 rounded-xl p-5">
          <h3 class="font-bold mb-3">
            {p.name} , {(p.additives_tags || []).length} additif{(p.additives_tags || []).length > 1 ? "s" : ""}
          </h3>
          {(p.additives_tags || []).length === 0 ? (
            <p class="text-sm text-stone-500">Aucun additif detecte.</p>
          ) : (
            <div class="flex flex-wrap gap-2">
              {(p.additives_tags || []).slice(0, 20).map((tag) => {
                const lower = tag.toLowerCase();
                const parts = lower.split(":");
                const eNum = parts[parts.length - 1];
                return (
                  <span class="inline-block px-2.5 py-1 rounded-full bg-stone-100 text-stone-700 text-xs font-mono">
                    {eNum.toUpperCase()}
                  </span>
                );
              })}
            </div>
          )}
        </div>
      ))}
    </section>

    <footer class="mt-12 text-sm text-stone-600 text-center">
      <a href={"/fr/vs/" + a.slug + "-vs-" + b.slug + "/"} class="text-teal-700 underline">Version francaise</a>
    </footer>
  </section>
</BaseLayout>
