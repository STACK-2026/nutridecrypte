---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import {
  getAllAdditives,
  getAllProducts,
  type Additive,
  type Product,
} from "../../../lib/data";
import { jsonLdDataset, isoDate } from "../../../utils/seo";
import { siteConfig } from "../../../../site.config";

export async function getStaticPaths() {
  const additives = await getAllAdditives();
  const products = await getAllProducts(1000);
  return additives
    .filter((a) => a.slug)
    .map((a) => {
      const matches = products
        .filter((p) =>
          (p.additives_tags || []).some((tag) => {
            const lower = tag.toLowerCase();
            return lower.includes(a.e_number.toLowerCase()) || lower.endsWith(":" + a.slug);
          })
        )
        .slice(0, 10);
      const related = a.category
        ? additives.filter((x) => x.slug && x.slug !== a.slug && x.category === a.category).slice(0, 5)
        : [];
      return { params: { slug: a.slug }, props: { additive: a, products: matches, related } };
    });
}

const { additive, products, related } = Astro.props as { additive: Additive; products: Product[]; related: Additive[] };

const categoryUses: Record<string, string> = {
  preservative: "préserver les produits contre les moisissures, les levures et les bactéries, surtout dans les sodas, sauces, conserves et pains préemballés",
  antioxidant: "empêcher les huiles et matières grasses de rancir, fréquent dans les margarines, biscuits, snacks et charcuterie industrielle",
  colour: "restaurer ou intensifier la couleur perdue lors de la transformation industrielle, principalement dans les confiseries, sodas, sauces et plats préparés",
  emulsifier: "lier l'eau et l'huile pour stabiliser la texture des margarines, glaces, mayonnaises, plats préparés et pâtisseries ultra-transformées",
  thickener: "épaissir les desserts laitiers, sauces, soupes et boissons végétales",
  stabiliser: "empêcher la séparation des ingrédients pendant la conservation, courant dans les sauces, desserts laitiers, plats préparés et boissons",
  sweetener: "remplacer le sucre dans les boissons allégées, desserts laitiers, chewing-gums et édulcorants de table",
  "flavour enhancer": "amplifier le goût salé ou umami dans les soupes, snacks, nouilles instantanées, sauces et viandes transformées",
  acidulant: "ajuster l'acidité à un pH cible, utilisé dans les sodas, bonbons, confitures et desserts laitiers",
  "anti-caking agent": "empêcher l'agglomération des poudres et granulés, courant dans le sel, mélanges d'épices, fromages râpés et boissons en poudre",
};
const lcCategory = (additive.category || "").toLowerCase();
const usesCopy = Object.keys(categoryUses).find((k) => lcCategory.includes(k))
  ? categoryUses[Object.keys(categoryUses).find((k) => lcCategory.includes(k)) as string]
  : "diverses fonctions technologiques dans les formulations alimentaires industrielles";

const riskColor: Record<string, string> = {
  low: "bg-emerald-50 text-emerald-800 border-emerald-200",
  medium: "bg-amber-50 text-amber-800 border-amber-200",
  high: "bg-red-50 text-red-800 border-red-200",
  unknown: "bg-stone-50 text-stone-700 border-stone-200",
};

const riskLabel: Record<string, string> = {
  low: "Risque faible",
  medium: "Risque moyen",
  high: "Risque élevé",
  unknown: "Inconnu",
};

const name = additive.name_fr || additive.name_en || additive.e_number;

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url + "/fr/" },
  { name: "Additifs", url: siteConfig.url + "/fr/encyclopedie/" },
  { name: `${additive.e_number} , ${name}`, url: siteConfig.url + `/fr/encyclopedie/${additive.slug}/` },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const definedTermJsonLd: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: `${additive.e_number} , ${name}`,
  alternateName: additive.e_number,
  description: additive.summary_fr || additive.summary_en || `Additif alimentaire ${additive.e_number}`,
  url: siteConfig.url + `/fr/encyclopedie/${additive.slug}/`,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "Registre européen des additifs alimentaires",
    url: "https://www.efsa.europa.eu/",
  },
};

const productCount = products.length;
const inUseLabel = productCount > 0 ? `Présent dans ${productCount} produit${productCount > 1 ? "s" : ""}.` : "";

// Dataset first-party de cette entree additif. Chaque variable ci-dessous est
// affichee sur la page : le badge de risque EFSA, le badge controversé, la
// liste "Interdit ou restreint dans", et le nombre de produits le contenant.
const encyclopediaDatasetVariables = [
  "Additive risk level",
  "Controversy flag",
  "EU restriction status",
  ...(productCount > 0 ? ["Catalog usage count"] : []),
];
const encyclopediaDatasetJsonLd = jsonLdDataset({
  name: `Profil de risque NutriDécrypte pour ${additive.e_number} (${name})`,
  description: `Classification indépendante du risque de l'additif alimentaire ${additive.e_number} (${name}) : ${riskLabel[additive.risk_level || "unknown"].toLowerCase()}${additive.controversy ? ", signalé controversé" : ""}${additive.banned_in && additive.banned_in.length ? `, restreint dans ${additive.banned_in.length} juridiction${additive.banned_in.length > 1 ? "s" : ""}` : ""}, d'après les avis EFSA et ANSES.`,
  url: siteConfig.url + `/fr/encyclopedie/${additive.slug}/`,
  dateModified: isoDate(additive.last_reviewed_at || new Date()),
  variableMeasured: encyclopediaDatasetVariables,
  keywords: ["additifs alimentaires", "E-numéros", "EFSA", "ANSES", "risque additif"],
});

const title = `${name} (${additive.e_number}) , additif alimentaire à ${riskLabel[additive.risk_level || "unknown"].toLowerCase()} | NutriDécrypte`;
const summaryRaw = (additive.summary_fr || additive.summary_en || `Additif alimentaire ${additive.e_number} (${name}). Risque EFSA : ${riskLabel[additive.risk_level || "unknown"]}.`).trim();
const summaryClean = summaryRaw.endsWith(".") ? summaryRaw : summaryRaw + ".";
const description = `${name} (${additive.e_number}) : ${summaryClean}${inUseLabel ? " " + inUseLabel : ""}`.slice(0, 158);
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + `/fr/encyclopedie/${additive.slug}/`}
  alternates={{ en: `/encyclopedia/${additive.slug}/`, fr: `/fr/encyclopedie/${additive.slug}/` }}
  jsonLd={[definedTermJsonLd, breadcrumbJsonLd, encyclopediaDatasetJsonLd]}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-mono text-teal-700 mb-2">{additive.e_number}</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{additive.e_number} , {name}</h1>
      <div class="flex flex-wrap gap-2 items-center">
        <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold border ${riskColor[additive.risk_level] || riskColor.unknown}`}>
          {riskLabel[additive.risk_level] || "Inconnu"}
        </span>
        {additive.controversy && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold bg-amber-50 text-amber-800 border border-amber-200">
            Controversé
          </span>
        )}
        {additive.category && (
          <span class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-stone-100 text-stone-700">
            {additive.category}
          </span>
        )}
      </div>
    </header>

    <aside data-speakable class="bg-stone-50 border-l-4 border-teal-600 rounded-r-xl p-6 mb-10">
      <p class="text-xs font-bold uppercase tracking-widest text-teal-700 mb-3">Résumé</p>
      <p class="text-base leading-relaxed text-stone-800">
        <strong>{additive.e_number}</strong> ({name}) est classé <strong>{(riskLabel[additive.risk_level] || "inconnu").toLowerCase()}</strong> dans l'encyclopédie NutriDécrypte.
        {additive.controversy ? " Il est signalé comme controversé par les évaluateurs indépendants." : ""}
        {additive.banned_in && additive.banned_in.length ? ` Interdit ou restreint dans : ${additive.banned_in.join(", ")}.` : ""}
        Les niveaux de risque suivent les avis EFSA (European Food Safety Authority) et ANSES publiés sur les registres officiels.
      </p>
    </aside>

    {(additive.summary_fr || additive.summary_en) && (
      <section class="prose max-w-none mb-10">
        <h2>Pourquoi ce classement</h2>
        <p class="text-base leading-relaxed text-stone-800">
          {additive.summary_fr || additive.summary_en}
        </p>
      </section>
    )}

    {additive.banned_in && additive.banned_in.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Interdit ou restreint dans</h2>
        <ul class="flex flex-wrap gap-2">
          {additive.banned_in.map((c) => (
            <li class="px-3 py-1.5 rounded-full bg-red-50 text-red-800 border border-red-200 text-sm">
              {c}
            </li>
          ))}
        </ul>
      </section>
    )}

    {additive.efsa_opinion_url && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Source officielle</h2>
        <a
          href={additive.efsa_opinion_url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-teal-700 hover:text-teal-900 underline font-medium"
        >
          Avis EFSA sur {additive.e_number} &rsaquo;
        </a>
      </section>
    )}

    {products.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Produits contenant {additive.e_number}</h2>
        <div class="grid gap-3">
          {products.map((p) => (
            <a
              href={`/fr/product/${p.slug}/`}
              class="flex items-center gap-3 bg-white border border-stone-200 rounded-lg p-3 hover:border-teal-400 transition"
            >
              {p.image_url ? (
                <img src={p.image_url} alt="" class="w-12 h-12 object-contain bg-stone-50 rounded flex-shrink-0" loading="lazy" width="48" height="48" />
              ) : (
                <div class="w-12 h-12 bg-stone-100 rounded flex-shrink-0"></div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-medium text-stone-900 truncate">{p.name}</p>
                {p.brand_slug && (
                  <p class="text-xs text-stone-500 truncate">{p.brand_slug.replace(/-/g, " ")}</p>
                )}
              </div>
              {p.grade && (
                <span
                  class={`text-sm font-extrabold px-2.5 py-1 rounded text-white`}
                  style={`background: var(--grade-${p.grade.toLowerCase()})`}
                >
                  {p.grade}
                </span>
              )}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="mb-10 prose max-w-none">
      <h2>Usages courants dans l'industrie alimentaire</h2>
      <p>
        {name} ({additive.e_number}) est utilisé par les industriels pour {usesCopy}.
        Sur l'étiquette, il apparaît le plus souvent sous le code <strong>{additive.e_number}</strong>, son nom <strong>{name}</strong>, ou un nom commercial.
        Sur une fiche produit NutriDécrypte, cet additif contribue à l'<em>axe additifs</em> (20 % de la note A à E), et déclenche un avertissement quand son risque EFSA est moyen ou élevé.
      </p>
      <p>
        Pour limiter ton exposition à cet additif, le réflexe le plus efficace est de lire la liste des ingrédients (pas seulement le recto), et de privilégier les produits notés A ou B dans notre <a href="/fr/classement/">catalogue indépendant</a>. Les catégories peu transformées (NOVA 1 ou 2) en contiennent rarement.
      </p>
    </section>

    {related.length > 0 && (
      <section class="mb-10">
        <h2 class="text-2xl font-bold mb-4">Additifs apparentés (même famille)</h2>
        <p class="text-stone-700 mb-4">
          Autres E-numéros classés <strong>{additive.category}</strong> dans le registre européen. Leur profil de risque et leur comportement sur l'étiquette sont souvent proches.
        </p>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2">
          {related.map((r) => (
            <li>
              <a href={`/fr/encyclopedie/${r.slug}/`} class="flex items-center justify-between bg-white border border-stone-200 rounded-lg px-4 py-2 hover:border-teal-400 transition">
                <span><strong>{r.e_number}</strong> , {r.name_fr || r.name_en || r.e_number}</span>
                <span class={`text-xs font-semibold px-2 py-0.5 rounded-full border ${riskColor[r.risk_level || "unknown"]}`}>
                  {riskLabel[r.risk_level || "unknown"]}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mb-10 prose max-w-none">
      <h2>Questions fréquentes</h2>
      <h3>L'additif {additive.e_number} ({name}) est-il sûr ?</h3>
      <p>
        L'EFSA classe le niveau de risque de {additive.e_number} comme <strong>{riskLabel[additive.risk_level || "unknown"].toLowerCase()}</strong> dans son dernier avis.
        {additive.controversy ? " Il est aussi signalé comme controversé par des toxicologues indépendants, ce qui veut dire que le consensus scientifique n'est pas unanime." : ""}
        {additive.banned_in && additive.banned_in.length ? ` Plusieurs juridictions l'ont restreint ou interdit, dont : ${additive.banned_in.join(", ")}.` : ""}
        Avant toute décision personnelle, lis l'avis officiel le plus récent et consulte un diététicien diplômé pour les questions médicales.
      </p>
      <h3>À quoi sert {additive.e_number} dans les produits du quotidien ?</h3>
      <p>
        Les industriels utilisent {name} principalement pour {usesCopy}. On le retrouve surtout dans les aliments ultra-transformés (NOVA 4) et rarement dans les produits bruts ou peu transformés (NOVA 1 ou 2).
      </p>
      <h3>Comment éviter {additive.e_number} sur une étiquette ?</h3>
      <p>
        Cherche le code <strong>{additive.e_number}</strong> ou son nom complet <strong>{name}</strong> dans la liste d'ingrédients, généralement écrite en petits caractères au dos du paquet. Les trois stratégies les plus fiables : cuisiner à partir d'ingrédients bruts, choisir des alternatives NOVA 1 ou 2, et filtrer par note A ou B dans le <a href="/fr/classement/">classement NutriDécrypte</a>.
      </p>
      {additive.efsa_opinion_url && (
        <>
          <h3>Où lire l'avis officiel EFSA ?</h3>
          <p>
            L'Autorité européenne de sécurité alimentaire publie son avis scientifique sur {additive.e_number} sur <a href={additive.efsa_opinion_url} target="_blank" rel="noopener noreferrer">{additive.efsa_opinion_url}</a>. L'ANSES, l'agence française, met régulièrement à jour ses propres positions sur cette molécule.
          </p>
        </>
      )}
    </section>

    <footer class="mt-12 p-6 bg-teal-50 border border-teal-200 rounded-xl text-center">
      <p class="text-sm text-stone-700">
        <a href="/fr/encyclopedie/" class="text-teal-800 font-medium underline">
          Tous les additifs &rsaquo;
        </a>
        {" · "}
        <a href={`/encyclopedia/${additive.slug}/`} class="text-teal-800 underline">
          English version
        </a>
      </p>
    </footer>
  </article>
</BaseLayout>
