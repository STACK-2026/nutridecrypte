---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { getAllAdditives, getAllProducts } from "../../../lib/data";
import { siteConfig } from "../../../../site.config";

const additives = await getAllAdditives();
const allProducts = await getAllProducts(1000);

const usageMap = new Map<string, number>();
for (const p of allProducts) {
  for (const tag of (p.additives_tags || [])) {
    const lower = tag.toLowerCase();
    for (const a of additives) {
      if (lower.includes(a.e_number.toLowerCase()) || lower.endsWith(":" + a.slug)) {
        usageMap.set(a.slug, (usageMap.get(a.slug) || 0) + 1);
      }
    }
  }
}

const additivesWithUsage = additives.map((a) => ({ ...a, usage: usageMap.get(a.slug) || 0 }));

const stats = {
  total: additives.length,
  high: additives.filter((a) => a.risk_level === "high").length,
  medium: additives.filter((a) => a.risk_level === "medium").length,
  low: additives.filter((a) => a.risk_level === "low").length,
  controversial: additives.filter((a) => a.controversy).length,
  banned: additives.filter((a) => a.banned_in && a.banned_in.length > 0).length,
};

const mostUsed = [...additivesWithUsage].filter((a) => a.usage > 0).sort((x, y) => y.usage - x.usage).slice(0, 8);

const groups: Record<string, typeof additivesWithUsage> = {
  high: [],
  medium: [],
  low: [],
  unknown: [],
};
for (const a of additivesWithUsage) {
  const level = (a.risk_level || "unknown") as keyof typeof groups;
  if (!groups[level]) groups[level] = [];
  groups[level].push(a);
}

const groupOrder: Array<keyof typeof groups> = ["high", "medium", "low", "unknown"];
const labels: Record<string, string> = {
  high: "Risque élevé",
  medium: "Risque moyen",
  low: "Risque faible",
  unknown: "Inconnu",
};
const accents: Record<string, string> = {
  high: "border-red-400 bg-red-50",
  medium: "border-amber-400 bg-amber-50",
  low: "border-emerald-400 bg-emerald-50",
  unknown: "border-stone-300 bg-stone-50",
};

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url + "/fr/" },
  { name: "Encyclopédie des additifs", url: siteConfig.url + "/fr/encyclopedie/" },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const title = `Encyclopédie des additifs alimentaires , ${additives.length} E-numéros décodés | NutriDécrypte`;
const description = `${additives.length} additifs alimentaires expliqués, classés par niveau de risque EFSA et ANSES. E-numéros à risque, additifs controversés, et les produits qui les contiennent.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + "/fr/encyclopedie/"}
  alternates={{ en: "/encyclopedia/", fr: "/fr/encyclopedie/" }}
  jsonLd={breadcrumbJsonLd}
>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-700 mb-2">Encyclopédie</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Encyclopédie des additifs alimentaires</h1>
      <p class="text-lg text-stone-700 max-w-3xl mb-6">
        {additives.length} E-numéros décodés, classés par niveau de risque EFSA + ANSES. Comprends ce qu'est chaque additif, s'il est controversé, et quels produits du catalogue en contiennent.
      </p>

      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 max-w-3xl">
        <div class="px-3 py-2 rounded-lg bg-red-50 border border-red-200 text-center">
          <p class="text-2xl font-extrabold text-red-700">{stats.high}</p>
          <p class="text-[11px] uppercase tracking-wide text-red-700 font-semibold">Risque élevé</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-amber-50 border border-amber-200 text-center">
          <p class="text-2xl font-extrabold text-amber-700">{stats.medium}</p>
          <p class="text-[11px] uppercase tracking-wide text-amber-700 font-semibold">Risque moyen</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-emerald-50 border border-emerald-200 text-center">
          <p class="text-2xl font-extrabold text-emerald-700">{stats.low}</p>
          <p class="text-[11px] uppercase tracking-wide text-emerald-700 font-semibold">Risque faible</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-stone-100 border border-stone-200 text-center">
          <p class="text-2xl font-extrabold text-stone-700">{stats.controversial}</p>
          <p class="text-[11px] uppercase tracking-wide text-stone-600 font-semibold">Controversés</p>
        </div>
        <div class="px-3 py-2 rounded-lg bg-stone-100 border border-stone-200 text-center">
          <p class="text-2xl font-extrabold text-stone-700">{stats.banned}</p>
          <p class="text-[11px] uppercase tracking-wide text-stone-600 font-semibold">Restreints UE</p>
        </div>
      </div>

      <div class="mt-6 max-w-xl">
        <input
          type="search"
          id="additive-search"
          placeholder="Cherche par E-numéro ou nom (ex. e211, benzoate de sodium)"
          class="w-full px-4 py-2.5 border border-stone-300 rounded-lg text-sm focus:outline-none focus:border-teal-500 focus:ring-2 focus:ring-teal-100"
          aria-label="Rechercher un additif"
        />
      </div>
    </header>

    {mostUsed.length > 0 && (
      <section class="mb-10 p-5 bg-teal-50 border border-teal-200 rounded-xl">
        <h2 class="text-lg font-bold text-teal-900 mb-3">Additifs les plus présents dans le catalogue</h2>
        <p class="text-sm text-teal-800 mb-4">Les E-numéros les plus souvent détectés sur les {allProducts.length}+ produits déjà décodés. Clique pour lire le profil complet.</p>
        <div class="flex flex-wrap gap-2">
          {mostUsed.map((a) => (
            <a href={`/fr/encyclopedie/${a.slug}/`} class="inline-flex items-center gap-2 bg-white border border-teal-300 rounded-full px-3 py-1.5 text-sm hover:border-teal-500 transition">
              <span class="font-mono font-bold text-teal-800">{a.e_number}</span>
              <span class="text-stone-700">{a.name_fr || a.name_en}</span>
              <span class="text-xs text-stone-500">({a.usage}×)</span>
            </a>
          ))}
        </div>
      </section>
    )}

    {groupOrder.map((g) => {
      const arr = groups[g] || [];
      if (arr.length === 0) return null;
      return (
        <section class={`mb-10 border-l-4 rounded-r-xl p-6 ${accents[g]}`}>
          <div class="flex items-baseline justify-between mb-4">
            <h2 class="text-2xl font-bold">{labels[g]}</h2>
            <span class="text-sm text-stone-600">{arr.length} additif{arr.length > 1 ? "s" : ""}</span>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 additive-grid">
            {arr.map((a) => (
              <a
                href={`/fr/encyclopedie/${a.slug}/`}
                data-search={`${a.e_number} ${a.name_fr || ""} ${a.name_en || ""} ${a.category || ""}`.toLowerCase()}
                class="additive-card block bg-white border border-stone-200 rounded-lg p-4 hover:border-teal-400 hover:shadow-sm transition"
              >
                <p class="font-mono text-teal-700 text-xs mb-1">{a.e_number}</p>
                <p class="font-medium text-stone-900 mb-1">{a.name_fr || a.name_en}</p>
                {a.category && (
                  <p class="text-xs text-stone-500">{a.category}</p>
                )}
                <div class="flex items-center gap-2 mt-2">
                  {a.controversy && (
                    <span class="text-[11px] text-amber-700 font-semibold">Controversé</span>
                  )}
                  {a.usage > 0 && (
                    <span class="text-[11px] text-stone-500">{a.usage} produit{a.usage > 1 ? "s" : ""}</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}

    <footer class="mt-12 text-sm text-stone-600 text-center">
      <a href="/encyclopedia/" class="text-teal-700 underline">English version</a>
    </footer>
  </section>
</BaseLayout>

<script is:inline>
  const search = document.getElementById("additive-search");
  if (search) {
    search.addEventListener("input", (e) => {
      const q = e.target.value.toLowerCase().trim();
      document.querySelectorAll(".additive-card").forEach((card) => {
        const data = card.getAttribute("data-search") || "";
        card.style.display = !q || data.includes(q) ? "" : "none";
      });
    });
  }
</script>
