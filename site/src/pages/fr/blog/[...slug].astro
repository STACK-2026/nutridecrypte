---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { getCollection, render } from "astro:content";
import AmazonPicks from "../../../components/AmazonPicks.astro";

export async function getStaticPaths() {
  const now = new Date();
  const allPosts = await getCollection("blog");
  const frPosts = allPosts.filter(
    (p) => !p.data.draft && p.data.date <= now && p.data.lang === "fr"
  );
  // Build the set of EN article IDs that are published and share the same slug.
  // If a FR article has a matching EN slug, the lang switcher can point to it
  // directly; otherwise it falls back to the EN blog index.
  const enPublishedIds = new Set(
    allPosts
      .filter((p) => p.data.lang !== "fr" && !p.data.draft && p.data.date <= now)
      .map((p) => p.id)
  );
  return frPosts.map((post) => ({
    params: { slug: post.id },
    props: { post, hasEnCounterpart: enPublishedIds.has(post.id) },
  }));
}

const { post, hasEnCounterpart } = Astro.props;
const { Content } = await render(post);
// Point the EN hreflang/lang-switcher to the real EN article when it shares
// the same slug, otherwise fall back to the EN blog index to avoid 404s.
const alternates = { en: hasEnCounterpart ? `/blog/${post.id}/` : `/blog/` };
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  author={post.data.author}
  category={post.data.category}
  tags={post.data.tags}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  slug={post.id}
  keywords={post.data.keywords}
  lastReviewed={post.data.lastReviewed}
  reviewedBy={post.data.reviewedBy}
  tldr={post.data.tldr}
  faq={post.data.faq}
  body={post.body}
  alternates={alternates}
>
  <Content />
  <AmazonPicks slug={`fr-blog-${post.id}`} count={4} />
</BlogLayout>
