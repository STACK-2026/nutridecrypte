---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import { getAllProducts, type Product } from "../../../lib/data";
import { siteConfig } from "../../../../site.config";

const all = await getAllProducts(1000);
const top = all.filter((p) => p.slug && p.score_overall != null).slice(0, 20);

const seen = new Set<string>();
const pairs: Array<{ a: Product; b: Product; key: string; gap: number }> = [];
for (let i = 0; i < top.length; i++) {
  for (let j = i + 1; j < top.length; j++) {
    const [a, b] = top[i].slug < top[j].slug ? [top[i], top[j]] : [top[j], top[i]];
    const key = a.slug + "-vs-" + b.slug;
    if (seen.has(key)) continue;
    seen.add(key);
    pairs.push({
      a,
      b,
      key,
      gap: Math.abs((a.score_overall || 0) - (b.score_overall || 0)),
    });
    if (pairs.length >= 30) break;
  }
  if (pairs.length >= 30) break;
}

const sortedPairs = [...pairs].sort((p, q) => p.gap - q.gap);

const breadcrumbs = [
  { name: "Accueil", url: siteConfig.url + "/fr/" },
  { name: "Comparer", url: siteConfig.url + "/fr/comparer/" },
];

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: b.name,
    item: b.url,
  })),
};

const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  numberOfItems: pairs.length,
  itemListElement: pairs.slice(0, 30).map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: siteConfig.url + "/fr/vs/" + p.key + "/",
    name: p.a.name + " vs " + p.b.name,
  })),
};

const title = `Comparer des produits alimentaires , ${pairs.length} décryptages côte à côte | NutriDécrypte`;
const description = `${pairs.length} comparaisons indépendantes A à E entre produits alimentaires et compléments. Nutri-Score, NOVA, additifs, allégations et densité comparés côte à côte.`;
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={siteConfig.url + "/fr/comparer/"}
  alternates={{ en: "/compare/", fr: "/fr/comparer/" }}
  jsonLd={[breadcrumbJsonLd, itemListJsonLd]}
>
  <section class="max-w-5xl mx-auto px-4 py-12">
    <Breadcrumbs items={breadcrumbs} />

    <header class="mb-10">
      <p class="text-sm font-bold uppercase tracking-widest text-teal-700 mb-2">Comparer</p>
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
        {pairs.length} comparaisons côte à côte
      </h1>
      <p class="text-lg text-stone-700 max-w-3xl">
        Chaque page de comparaison décode deux produits sur les mêmes cinq axes
        (Nutri-Score, classification NOVA, risque additifs, allégations marketing, densité nutritionnelle).
        Verdicts indépendants, aucune marque ne paie.
      </p>
    </header>

    <div class="mb-6 flex items-center gap-3 text-sm text-stone-600">
      <span class="px-3 py-1 rounded-full bg-stone-100 font-medium">Trié par scores les plus proches</span>
      <span class="hidden sm:inline">·</span>
      <a href="/fr/classement/" class="text-teal-700 hover:text-teal-900 underline">Choisir une autre paire dans le catalogue</a>
    </div>

    <div class="grid sm:grid-cols-2 gap-3">
      {sortedPairs.map((p) => (
        <a
          href={`/fr/vs/${p.key}/`}
          class="group block bg-white border border-stone-200 rounded-xl p-4 hover:border-teal-400 hover:shadow-sm transition"
        >
          <div class="flex items-stretch gap-3">
            <div class="flex-1 min-w-0 text-center">
              <p class="font-medium text-stone-900 truncate text-sm">{p.a.name}</p>
              {p.a.brand_slug && (
                <p class="text-[11px] text-stone-500 truncate">{p.a.brand_slug.replace(/-/g, " ")}</p>
              )}
              {p.a.grade && (
                <span
                  class="inline-block mt-1 text-xs font-extrabold px-2 py-0.5 rounded text-white"
                  style={`background: var(--grade-${p.a.grade.toLowerCase()})`}
                >
                  {p.a.grade}
                </span>
              )}
            </div>
            <div class="flex items-center justify-center text-stone-400 font-bold text-xs px-2">
              VS
            </div>
            <div class="flex-1 min-w-0 text-center">
              <p class="font-medium text-stone-900 truncate text-sm">{p.b.name}</p>
              {p.b.brand_slug && (
                <p class="text-[11px] text-stone-500 truncate">{p.b.brand_slug.replace(/-/g, " ")}</p>
              )}
              {p.b.grade && (
                <span
                  class="inline-block mt-1 text-xs font-extrabold px-2 py-0.5 rounded text-white"
                  style={`background: var(--grade-${p.b.grade.toLowerCase()})`}
                >
                  {p.b.grade}
                </span>
              )}
            </div>
          </div>
          <p class="mt-3 text-[11px] text-stone-500 text-center group-hover:text-teal-700 transition">
            Écart : {p.gap} pts , voir le décryptage &rsaquo;
          </p>
        </a>
      ))}
    </div>

    <section class="mt-12 prose max-w-none">
      <h2>Comment NutriDécrypte compare deux produits</h2>
      <p>
        Chaque page côte à côte recalcule les deux produits depuis les données brutes Open Food Facts, applique l'algorithme A à E déterministe, et affiche les cinq sous-scores pour voir exactement où se creuse l'écart. Même algorithme, aucun trucage marketing.
      </p>
      <ul>
        <li><strong>Nutri-Score (25 %)</strong> , l'étiquette nutritionnelle officielle UE</li>
        <li><strong>Groupe NOVA (25 %)</strong> , niveau d'ultra-transformation</li>
        <li><strong>Additifs (20 %)</strong> , indice pondéré du risque EFSA</li>
        <li><strong>Audit allégations (15 %)</strong> , allégations marketing vs composition réelle</li>
        <li><strong>Densité nutritionnelle (15 %)</strong> , protéines, fibres, sucres, sel, énergie</li>
      </ul>
      <p>
        Tu veux comparer un produit qui n'est pas dans la liste ci-dessus ? Ouvre le <a href="/fr/classement/">catalogue complet</a>, choisis deux slugs, puis visite <code>/fr/vs/&lt;slug-a&gt;-vs-&lt;slug-b&gt;/</code> directement , la page est générée pour les meilleures combinaisons du catalogue.
      </p>
    </section>

    <footer class="mt-12 text-sm text-stone-600 text-center">
      <a href="/compare/" class="text-teal-700 underline">English version</a>
    </footer>
  </section>
</BaseLayout>
