# Cloudflare Pages headers , NutriDecrypte
# Security + caching for a fully static Astro site.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://*.supabase.co; frame-ancestors 'none'; base-uri 'self'

# HTML cached 60s at the edge, 0 in browser. Gets revalidated via If-Modified-Since.
/*.html
  Cache-Control: public, max-age=0, must-revalidate, s-maxage=60

# Static assets (CSS, JS, images, fonts) cached aggressively with hashed names
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.svg
  Cache-Control: public, max-age=86400

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/tracker.js
  Cache-Control: public, max-age=86400
